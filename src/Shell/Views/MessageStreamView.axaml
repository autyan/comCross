<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ComCross.Shell.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="ComCross.Shell.Views.MessageStreamView"
             x:DataType="vm:MessageStreamViewModel">
    
    <Grid RowDefinitions="Auto,Auto,Auto,*">
        <!-- Current Session Context -->
        <Border Grid.Row="0" Background="{StaticResource Bg0Brush}" Padding="16,10" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="{Binding CurrentSessionLabel}"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="{StaticResource Text2Brush}" />
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ActiveSessionDisplayName}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Text0Brush}"
                                   VerticalAlignment="Center" />
                        <Border Background="{StaticResource Bg2Brush}"
                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="1"
                                CornerRadius="999"
                                Padding="8,2">
                            <TextBlock Text="{Binding ActiveSessionStatusLabel}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Text1Brush}" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding ActiveSessionDetailText}"
                               FontSize="11"
                               Foreground="{StaticResource Text2Brush}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <Button Grid.Column="1"
                        Height="28"
                        Padding="10,0"
                        Margin="8,0,0,0"
                        Click="OnToggleMetricsClick">
                    <TextBlock Text="统计"
                               FontSize="11"
                               Foreground="{StaticResource Text1Brush}"
                               VerticalAlignment="Center" />
                </Button>
                <Button Grid.Column="2"
                        Width="28"
                        Height="28"
                        Padding="0"
                        Margin="8,0,0,0"
                        Click="OnToggleRightDockClick">
                    <Path Data="{StaticResource Maximize2Icon}"
                          Width="14"
                          Height="14"
                          Stretch="Uniform"
                          Stroke="{StaticResource Text1Brush}"
                          StrokeThickness="1.6"
                          StrokeLineCap="Round"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />
                </Button>
                <Button Grid.Column="3"
                        Width="28"
                        Height="28"
                        Padding="0"
                        Margin="8,0,0,0"
                        Click="OnExportMessagesClick">
                    <Path Data="{StaticResource DownloadIcon}"
                          Width="14"
                          Height="14"
                          Stretch="Uniform"
                          Stroke="{StaticResource Text1Brush}"
                          StrokeThickness="1.6"
                          StrokeLineCap="Round"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />
                </Button>
                <Button Grid.Column="4"
                        Width="28"
                        Height="28"
                        Padding="0"
                        Margin="8,0,0,0"
                        Click="OnClearMessagesClick">
                    <Path Data="{StaticResource Trash2Icon}"
                          Width="14"
                          Height="14"
                          Stretch="Uniform"
                          Stroke="{StaticResource Text1Brush}"
                          StrokeThickness="1.6"
                          StrokeLineCap="Round"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />
                </Button>
            </Grid>
        </Border>

        <!-- Search Bar -->
        <Border Grid.Row="1" Background="{StaticResource Bg1Brush}" Padding="16,12" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,70,Auto">
                <Border Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Classes="prototype-search-shell">
                    <Grid ColumnDefinitions="16,*" VerticalAlignment="Center">
                        <Path Classes="prototype-icon"
                              Data="{StaticResource SearchIcon}"
                              Width="14"
                              Height="14"
                              Stroke="{StaticResource Text2Brush}"
                              VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchQuery}"
                                 Classes="prototype-search-input"
                                 Margin="10,0,0,0"
                                 Watermark="{Binding L[stream.search.placeholder]}" />
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Margin="12,0,0,0"
                        CornerRadius="{StaticResource RadiusSm}"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="1"
                        Background="{StaticResource Bg0Brush}"
                        Width="58"
                        Height="40"
                        Padding="0"
                        Cursor="Hand"
                        PointerPressed="OnToggleDisplayMode">
                    <TextBlock Text="{Binding DisplayModeLabel}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource Text0Brush}" />
                </Border>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="8"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center">
                    <CheckBox IsChecked="{Binding ActiveSession.EnableDatabaseStorage}"
                              Content="{Binding L[session.database.enable]}"
                              FontSize="11"
                              VerticalAlignment="Center" />
                    <Border Background="{StaticResource WarnBrush}"
                            CornerRadius="8"
                            Width="16"
                            Height="16"
                            VerticalAlignment="Center"
                            ToolTip.Tip="{Binding L[session.database.tooltip]}">
                        <TextBlock Text="?"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource Bg1Brush}" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Metrics Bar -->
        <Border Grid.Row="2"
                IsVisible="{Binding IsMetricsBarVisible}"
                Background="{StaticResource Bg1Brush}"
                Padding="16,8"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="24" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding L[stream.metrics.rx]}" FontSize="10" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ActiveSession.RxBytes}" FontSize="12" Foreground="{StaticResource AccentCyanBrush}" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding L[stream.metrics.tx]}" FontSize="10" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ActiveSession.TxBytes}" FontSize="12" Foreground="{StaticResource AccentBlueBrush}" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding L[stream.metrics.lines]}" FontSize="10" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding MessageItems.Count}" FontSize="12" Foreground="{StaticResource Text0Brush}" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>

            </StackPanel>
        </Border>

        <!-- Message List -->
        <ListBox Grid.Row="3"
                 x:Name="MessageList"
                 ItemsSource="{Binding MessageItems}" 
                 Background="{StaticResource Bg0Brush}" 
                 BorderThickness="0"
                 SelectionMode="Single"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 FontFamily="{Binding Display.MessageFontFamily}"
                FontSize="{Binding Display.MessageFontSize}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:LogMessageListItemViewModel">
                    <Border Padding="8,2" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="Auto,Auto,Auto,*" Height="20">
                            <!-- Direction Indicator (TX/RX) -->
                            <Border Grid.Column="0" Width="2" Background="{Binding Source, Converter={StaticResource DirectionColorConverter}}" Margin="0,0,8,0" CornerRadius="1" VerticalAlignment="Stretch" />
                            
                            <!-- Timestamp -->
                            <TextBlock Grid.Column="1" 
                                       Text="{Binding TimestampText}"
                                       Foreground="{StaticResource TextMutedBrush}" 
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            
                            <!-- Direction (TX/RX) -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Source}"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding Source, Converter={StaticResource DirectionColorConverter}}"
                                       Margin="0,0,8,0"
                                       Width="24"
                                       VerticalAlignment="Center" />
                            
                            <!-- Content -->
                            <TextBlock Grid.Column="3" 
                                       Text="{Binding Content}" 
                                       Foreground="{StaticResource Text0Brush}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
