<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ComCross.Shell.ViewModels"
             xmlns:controls="using:ComCross.Shell.Controls"
             xmlns:ae="using:AvaloniaEdit"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="ComCross.Shell.Views.MessageStreamView"
             x:DataType="vm:MessageStreamViewModel">

    <UserControl.Styles>
        <Style Selector="Button.latest-floating-button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Button.latest-floating-button:pointerover">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button.latest-floating-button:pressed">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="ae|TextEditor.aggregate-message-editor">
            <Setter Property="Background" Value="{StaticResource Bg0Brush}" />
            <Setter Property="Foreground" Value="{StaticResource Text0Brush}" />
        </Style>
        <Style Selector="ae|TextEditor.aggregate-message-editor:pointerover">
            <Setter Property="Background" Value="{StaticResource Bg0Brush}" />
        </Style>
        <Style Selector="ae|TextEditor.aggregate-message-editor:focus">
            <Setter Property="Background" Value="{StaticResource Bg0Brush}" />
        </Style>
        <Style Selector="ae|TextEditor.aggregate-message-editor:focus-within">
            <Setter Property="Background" Value="{StaticResource Bg0Brush}" />
        </Style>
        <Style Selector="Border.latest-floating-button-frame">
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrightBrush}" />
            <Setter Property="BoxShadow" Value="0 8 18 0 #66000000" />
        </Style>
        <Style Selector="Button.latest-floating-button:pointerover Border.latest-floating-button-frame">
            <Setter Property="BorderBrush" Value="{StaticResource WhiteBrush}" />
            <Setter Property="BoxShadow" Value="0 10 24 0 #80000000" />
        </Style>
    </UserControl.Styles>
    
    <Grid RowDefinitions="Auto,Auto,Auto,*">
        <!-- Current Session Context -->
        <Border Grid.Row="0" Background="{StaticResource Bg0Brush}" Padding="16,10" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto">
                <StackPanel Grid.Column="0" Spacing="4" MinWidth="300" MaxWidth="420">
                    <TextBlock Text="{Binding CurrentSessionLabel}"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="{StaticResource Text2Brush}" />
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ActiveSessionDisplayName}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Text0Brush}"
                                   VerticalAlignment="Center" />
                        <Border Background="{StaticResource Bg2Brush}"
                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="1"
                                CornerRadius="999"
                                Padding="8,2">
                            <TextBlock Text="{Binding ActiveSessionStatusLabel}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Text1Brush}" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding ActiveSessionDetailText}"
                               FontSize="11"
                               Foreground="{StaticResource Text2Brush}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <Grid Grid.Column="2"
                      ColumnDefinitions="Auto,6,Auto"
                      Margin="12,0,0,0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center">
                    <controls:OptionDropDown ItemsSource="{Binding DataSourceOptions}"
                                             SelectedItem="{Binding SelectedDataSourceOption}"
                                             ToolTipText="{Binding L[stream.source.label]}"
                                             Width="84"
                                             Height="28" />
                    <controls:SwitchCheckBox Grid.Column="2"
                                             Label="{Binding L[session.archive.label]}"
                                             IsChecked="{Binding IsArchiveWriting}"
                                             IsEnabled="{Binding CanToggleArchiveWriting}"
                                             AutoToggle="False"
                                             ToolTip.Tip="{Binding ArchiveStatusTooltip}"
                                             ToggleRequested="OnArchiveSwitchToggleRequested" />
                </Grid>

                <Border Grid.Column="3"
                        Width="1"
                        Height="28"
                        Margin="10,0,2,0"
                        Background="{StaticResource BorderSubtleBrush}"
                        VerticalAlignment="Center" />

                <Button Grid.Column="4"
                        Height="28"
                        Padding="10,0"
                        Margin="6,0,0,0"
                        Click="OnToggleMetricsClick">
                    <TextBlock Text="{Binding L[stream.metrics.toggle]}"
                               FontSize="11"
                               Foreground="{StaticResource Text1Brush}"
                               VerticalAlignment="Center" />
                </Button>
                <Button Grid.Column="5"
                        Width="28"
                        Height="28"
                        Padding="0"
                        Margin="6,0,0,0"
                        Click="OnToggleRightDockClick">
                    <Path Data="{StaticResource Maximize2Icon}"
                          Width="14"
                          Height="14"
                          Stretch="Uniform"
                          Stroke="{StaticResource Text1Brush}"
                          StrokeThickness="1.6"
                          StrokeLineCap="Round"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />
                </Button>
                <Button Grid.Column="6"
                        Width="28"
                        Height="28"
                        Padding="0"
                        Margin="6,0,0,0"
                        Click="OnExportMessagesClick">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{Binding L[stream.export.plain]}" Click="OnExportPlainClick" />
                            <MenuItem Header="{Binding L[stream.export.slim]}" Click="OnExportSlimClick" />
                            <MenuItem Header="{Binding L[stream.export.detailed]}" Click="OnExportDetailedClick" />
                        </ContextMenu>
                    </Button.ContextMenu>
                    <Path Data="{StaticResource DownloadIcon}"
                          Width="14"
                          Height="14"
                          Stretch="Uniform"
                          Stroke="{StaticResource Text1Brush}"
                          StrokeThickness="1.6"
                          StrokeLineCap="Round"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />
                </Button>
                <Button Grid.Column="7"
                        Width="28"
                        Height="28"
                        Padding="0"
                        Margin="6,0,0,0"
                        Click="OnClearMessagesClick">
                    <Path Data="{StaticResource Trash2Icon}"
                          Width="14"
                          Height="14"
                          Stretch="Uniform"
                          Stroke="{StaticResource Text1Brush}"
                          StrokeThickness="1.6"
                          StrokeLineCap="Round"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />
                </Button>
            </Grid>
        </Border>

        <!-- Search Bar -->
        <Border Grid.Row="1" Background="{StaticResource Bg1Brush}" Padding="16,12" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <Border Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Classes="prototype-search-shell">
                    <Grid ColumnDefinitions="16,*,Auto" VerticalAlignment="Center">
                        <Path Classes="prototype-icon"
                              Data="{StaticResource SearchIcon}"
                              Width="14"
                              Height="14"
                              Stroke="{StaticResource Text2Brush}"
                              VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchQuery}"
                                 Classes="prototype-search-input prototype-embedded-input"
                                 Margin="10,0,0,0"
                                 PlaceholderText="{Binding L[stream.search.placeholder]}" />
                        <Button Grid.Column="2"
                                Width="28"
                                Height="28"
                                Padding="0"
                                IsVisible="{Binding HasSearchQuery}"
                                Click="OnClearSearchClick">
                            <Path Data="{StaticResource XIcon}"
                                  Width="12"
                                  Height="12"
                                  Stretch="Uniform"
                                  Stroke="{StaticResource Text2Brush}"
                                  StrokeThickness="1.8"
                                  StrokeLineCap="Round" />
                        </Button>
                    </Grid>
                </Border>

                <controls:SwitchCheckBox Grid.Column="1"
                                         Label="{Binding DisplayModeLabel}"
                                         IsChecked="{Binding IsPayloadHexMode}"
                                         AutoToggle="False"
                                         ToolTip.Tip="{Binding DisplayModeLabel}"
                                         ToggleRequested="OnDisplayModeToggleRequested"
                                         Margin="12,0,0,0"
                                         Height="40"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center" />

                <controls:OptionDropDown Grid.Column="2"
                                         ItemsSource="{Binding DisplayDensityOptions}"
                                         SelectedItem="{Binding SelectedDisplayDensityOption}"
                                         ToolTipText="{Binding DisplayDensityLabel}"
                                         Margin="8,0,0,0"
                                         Width="102"
                                         Height="40" />
            </Grid>
        </Border>

        <!-- Metrics Bar -->
        <Border Grid.Row="2"
                IsVisible="{Binding IsMessageStatusBarVisible}"
                Background="{StaticResource Bg1Brush}"
                Padding="16,8"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="24" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsMetricsBarVisible}">
                        <TextBlock Text="{Binding L[stream.metrics.rx]}" FontSize="10" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ActiveSession.RxBytes}" FontSize="12" Foreground="{StaticResource AccentCyanBrush}" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsMetricsBarVisible}">
                        <TextBlock Text="{Binding L[stream.metrics.tx]}" FontSize="10" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ActiveSession.TxBytes}" FontSize="12" Foreground="{StaticResource AccentBlueBrush}" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsMetricsBarVisible}">
                        <TextBlock Text="{Binding L[stream.metrics.lines]}" FontSize="10" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding MessageItems.Count}" FontSize="12" Foreground="{StaticResource Text0Brush}" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding HasSearchStatus}">
                        <TextBlock Text="{Binding L[stream.search.status]}" FontSize="10" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding SearchStatus}" FontSize="12" Foreground="{StaticResource Text0Brush}" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>

            </StackPanel>
        </Border>

        <!-- Message Viewer -->
        <Grid Grid.Row="3" Background="{StaticResource Bg0Brush}">
            <ListBox x:Name="MessageList"
                     IsVisible="{Binding IsDetailedDisplayMode}"
                     ItemsSource="{Binding MessageItems}"
                     Background="{StaticResource Bg0Brush}"
                     BorderThickness="0"
                     SelectionMode="Single"
                     SelectedItem="{Binding SelectedMessageItem, Mode=TwoWay}"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     FontFamily="{Binding Display.MessageFontFamily}"
                     FontSize="{Binding Display.MessageFontSize}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:LogMessageListItemViewModel">
                        <Border Padding="{Binding RowPadding}"
                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="{Binding RowBorderThickness}">
                            <Grid ColumnDefinitions="Auto,*">
                                <Border Grid.ColumnSpan="2"
                                        Background="{StaticResource BgHighlightBrush}"
                                        Opacity="0.34"
                                        CornerRadius="4"
                                        IsVisible="{Binding ShowSearchMatchBackground}" />
                                <Border Grid.ColumnSpan="2"
                                        Background="{StaticResource AccentBlueBrush}"
                                        Opacity="0.16"
                                        CornerRadius="4"
                                        IsVisible="{Binding IsCurrentSearchMatch}" />
                                <Border Grid.Column="0"
                                        IsVisible="{Binding ShowDirectionMarker}"
                                        Width="3"
                                        Background="{Binding Source, Converter={StaticResource DirectionColorConverter}}"
                                        Margin="0,0,8,0"
                                        CornerRadius="1"
                                        VerticalAlignment="Stretch" />
                                <Border Grid.Column="0"
                                        IsVisible="{Binding IsCurrentSearchMatch}"
                                        Width="3"
                                        Background="{StaticResource AccentBlueBrightBrush}"
                                        Margin="0,0,8,0"
                                        CornerRadius="1"
                                        VerticalAlignment="Stretch" />

                                <Grid Grid.Column="1" RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,Auto,*">
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               IsVisible="{Binding ShowTimestamp}"
                                               Text="{Binding TimestampText}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               IsVisible="{Binding ShowSource}"
                                               Text="{Binding Source}"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding Source, Converter={StaticResource DirectionColorConverter}}"
                                               Margin="0,0,8,0"
                                               Width="24"
                                               VerticalAlignment="Center" />

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="2"
                                               Text="{Binding Content}"
                                               Foreground="{StaticResource Text0Brush}"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />

                                    <ItemsControl Grid.Row="1"
                                                  Grid.Column="2"
                                                  IsVisible="{Binding HasVisibleAttributes}"
                                                  ItemsSource="{Binding Attributes}"
                                                  Margin="0,3,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:MessageAttributeListItemViewModel">
                                                <Border Background="{StaticResource Bg2Brush}"
                                                        BorderBrush="{StaticResource BorderSubtleBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="5,1"
                                                        Margin="0,0,4,3"
                                                        ToolTip.Tip="{Binding DisplayText}">
                                                    <TextBlock Text="{Binding DisplayText}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource Text2Brush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="180" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <ae:TextEditor x:Name="PlainAggregateMessageEditor"
                           Classes="aggregate-message-editor"
                           IsVisible="{Binding IsPlainAggregateTextMode}"
                           IsReadOnly="True"
                           Background="{StaticResource Bg0Brush}"
                           Foreground="{StaticResource Text0Brush}"
                           Padding="18,12"
                           WordWrap="True"
                           HorizontalScrollBarVisibility="Disabled"
                           VerticalScrollBarVisibility="Auto"
                           FontFamily="{Binding Display.MessageFontFamily}"
                           FontSize="{Binding Display.MessageFontSize}" />

            <ae:TextEditor x:Name="SlimAggregateMessageEditor"
                           Classes="aggregate-message-editor"
                           IsVisible="{Binding IsSlimAggregateTextMode}"
                           IsReadOnly="True"
                           Background="{StaticResource Bg0Brush}"
                           Foreground="{StaticResource Text0Brush}"
                           Padding="8,12,18,12"
                           WordWrap="True"
                           HorizontalScrollBarVisibility="Disabled"
                           VerticalScrollBarVisibility="Auto"
                           FontFamily="{Binding Display.MessageFontFamily}"
                           FontSize="{Binding Display.MessageFontSize}" />

            <Border HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,10,18,0"
                    Width="62"
                    Background="{StaticResource Bg1Brush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="5"
                    IsVisible="{Binding HasSearchMatches}">
                <Grid RowDefinitions="30,24,30">
                    <Button Grid.Row="0"
                            Width="40"
                            Height="30"
                            Padding="0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            HorizontalAlignment="Center"
                            IsEnabled="{Binding CanNavigateSearch}"
                            Click="OnPreviousSearchResultClick">
                        <Viewbox Width="14"
                                 Height="14"
                                 Stretch="Uniform"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Path Data="{StaticResource ChevronUpIcon}"
                                  Width="24"
                                  Height="24"
                                  Stretch="Uniform"
                                  Stroke="{StaticResource Text1Brush}"
                                  StrokeThickness="2"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round" />
                        </Viewbox>
                    </Button>
                    <Border Grid.Row="1"
                            Width="52"
                            Height="24"
                            Background="Transparent"
                            Padding="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding SearchNavigationStatus}"
                                   FontSize="11"
                                   Foreground="{StaticResource Text1Brush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <Button Grid.Row="2"
                            Width="40"
                            Height="30"
                            Padding="0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            HorizontalAlignment="Center"
                            IsEnabled="{Binding CanNavigateSearch}"
                            Click="OnNextSearchResultClick">
                        <Viewbox Width="14"
                                 Height="14"
                                 Stretch="Uniform"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Path Data="{StaticResource ChevronDownIcon}"
                                  Width="24"
                                  Height="24"
                                  Stretch="Uniform"
                                  Stroke="{StaticResource Text1Brush}"
                                  StrokeThickness="2"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round" />
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>

            <Button Classes="latest-floating-button"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,16"
                    MinWidth="118"
                    Height="34"
                    IsVisible="{Binding IsReturnToLatestVisible}"
                    Click="OnReturnToLatestClick">
                <Border Classes="latest-floating-button-frame"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14,0">
                    <Grid ColumnDefinitions="18,8,Auto"
                          Height="18"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        <Grid Width="18"
                              Height="18"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                            <Path Data="M4,7 L9,12 L14,7"
                                  Width="18"
                                  Height="18"
                                  Stretch="None"
                                  Stroke="{StaticResource WhiteBrush}"
                                  StrokeThickness="2.4"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock Text="{Binding L[stream.window.returnToLatest]}"
                                   Grid.Column="2"
                                   Height="18"
                                   FontSize="12"
                                   LineHeight="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource WhiteBrush}"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Button>
        </Grid>
    </Grid>
</UserControl>
