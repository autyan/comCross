<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ComCross.Shell.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="ComCross.Shell.Views.MessageStreamView"
             x:DataType="vm:MessageStreamViewModel">
    
    <Grid RowDefinitions="Auto,Auto,Auto,*">
        <!-- Current Session Context -->
        <Border Grid.Row="0" Background="#10171C" Padding="16,12" BorderBrush="#25303A" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="{Binding CurrentSessionLabel}"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="#87909B" />
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ActiveSessionDisplayName}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#E6EDF3"
                                   VerticalAlignment="Center" />
                        <Border Background="#1B242A"
                                BorderBrush="#25303A"
                                BorderThickness="1"
                                CornerRadius="999"
                                Padding="8,2">
                            <TextBlock Text="{Binding ActiveSessionStatusLabel}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#B7C1CC" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding ActiveSessionDetailText}"
                               FontSize="11"
                               Foreground="#87909B"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#141F27"
                        BorderBrush="#25303A"
                        BorderThickness="1"
                        CornerRadius="999"
                        Padding="10,4"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        IsVisible="{Binding HasActiveSession}">
                    <TextBlock Text="{Binding ActiveSessionTypeLabel}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#BDE3FF" />
                </Border>
            </Grid>
        </Border>

        <!-- Search Bar -->
        <Border Grid.Row="1" Background="#141B1F" Padding="16" BorderBrush="#25303A" BorderThickness="0,0,0,1">
            <TextBox Text="{Binding SearchQuery}" 
                     Watermark="{Binding L[stream.search.placeholder]}" 
                     Background="#1B242A"
                     BorderBrush="#25303A" />
        </Border>

        <!-- Metrics Bar -->
        <Border Grid.Row="2" Background="#141B1F" Padding="16,8" BorderBrush="#25303A" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="24" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding L[stream.metrics.rx]}" FontSize="10" Foreground="#87909B" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ActiveSession.RxBytes}" FontSize="12" Foreground="#2CB5A9" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding L[stream.metrics.tx]}" FontSize="10" Foreground="#87909B" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ActiveSession.TxBytes}" FontSize="12" Foreground="#3AA0FF" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding L[stream.metrics.lines]}" FontSize="10" Foreground="#87909B" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding MessageItems.Count}" FontSize="12" Foreground="#E6EDF3" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Core display mode toggle (STR/HEX) -->
                    <Border CornerRadius="6"
                            BorderBrush="#25303A"
                            BorderThickness="1"
                            Background="#0F1417"
                            Padding="10,6"
                            Cursor="Hand"
                            PointerPressed="OnToggleDisplayMode">
                        <TextBlock Text="{Binding DisplayModeLabel}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#E6EDF3" />
                    </Border>
                </StackPanel>
                
                <!-- Database Storage Toggle -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <CheckBox IsChecked="{Binding ActiveSession.EnableDatabaseStorage}" 
                              Content="{Binding L[session.database.enable]}"
                              FontSize="11"
                              VerticalAlignment="Center" />
                    <Border Background="#F5A524" CornerRadius="8" Width="16" Height="16" VerticalAlignment="Center"
                            ToolTip.Tip="{Binding L[session.database.tooltip]}">
                        <TextBlock Text="?" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#141B1F" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Message List -->
        <ListBox Grid.Row="3"
                 x:Name="MessageList"
                 ItemsSource="{Binding MessageItems}" 
                 Background="#0F1417" 
                 BorderThickness="0"
                 SelectionMode="Single"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 FontFamily="{Binding Display.MessageFontFamily}"
                 FontSize="{Binding Display.MessageFontSize}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:LogMessageListItemViewModel">
                    <Border Padding="8,2" BorderBrush="#25303A" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="Auto,Auto,Auto,*" Height="20">
                            <!-- Direction Indicator (TX/RX) -->
                            <Border Grid.Column="0" Width="2" Background="{Binding Source, Converter={StaticResource DirectionColorConverter}}" Margin="0,0,8,0" CornerRadius="1" VerticalAlignment="Stretch" />
                            
                            <!-- Timestamp -->
                            <TextBlock Grid.Column="1" 
                                       Text="{Binding TimestampText}"
                                       Foreground="#6B7780" 
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            
                            <!-- Direction (TX/RX) -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Source}"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding Source, Converter={StaticResource DirectionColorConverter}}"
                                       Margin="0,0,8,0"
                                       Width="24"
                                       VerticalAlignment="Center" />
                            
                            <!-- Content -->
                            <TextBlock Grid.Column="3" 
                                       Text="{Binding Content}" 
                                       Foreground="#E6EDF3"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
