<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ComCross.Shell.ViewModels"
             xmlns:views="using:ComCross.Shell.Views"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
             x:Class="ComCross.Shell.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
    <Grid ColumnDefinitions="220,*">
        <!-- Left navigation -->
        <Border Grid.Column="0" Background="#141B1F" BorderBrush="#25303A" BorderThickness="0,0,1,0">
            <StackPanel Margin="12" Spacing="8">
                <TextBlock Text="{Binding L[settings.title]}" FontSize="13" FontWeight="Bold" Foreground="#E6EDF3" />

                <ListBox ItemsSource="{Binding NavigationEntries}"
                         SelectedItem="{Binding SelectedNavigationEntry}"
                         Background="Transparent"
                         BorderThickness="0"
                         HorizontalAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,6" Background="Transparent" IsHitTestVisible="{Binding IsSelectable}">
                                <TextBlock Text="{Binding Title}"
                                           FontSize="{Binding TitleFontSize}"
                                           FontWeight="{Binding TitleFontWeight}"
                                           Foreground="{Binding TitleForeground}"
                                           Margin="{Binding TitleMargin}" />
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Right content -->
        <Grid Grid.Column="1">
            <!-- System settings page -->
            <ScrollViewer IsVisible="{Binding IsSystemSettingsSelected}">
                <StackPanel Spacing="16" Margin="20">
            <!-- General -->
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding L[settings.section.general]}" FontSize="13" FontWeight="Bold" Foreground="#E6EDF3" />
                <WrapPanel Orientation="Horizontal">
                    <StackPanel Width="280" Margin="0,0,12,8">
                        <TextBlock Text="{Binding L[settings.language]}" FontSize="11" Foreground="#B7C1CC" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding AvailableLanguages}" 
                                  SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}" 
                                  IsEnabled="{Binding !FollowSystemLanguage}"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding NativeName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Width="280" Margin="0,0,12,8">
                        <TextBlock Height="16" Margin="0,0,0,4" />
                        <CheckBox Content="{Binding L[settings.followSystemLanguage]}" IsChecked="{Binding FollowSystemLanguage}" />
                    </StackPanel>
                </WrapPanel>
            </StackPanel>

            <!-- App Logs -->
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding L[settings.section.appLogs]}" FontSize="13" FontWeight="Bold" Foreground="#E6EDF3" />
                <CheckBox Content="{Binding L[settings.appLogs.enabled]}" IsChecked="{Binding AppLogEnabled}" Margin="0,0,0,4" />
                <WrapPanel Orientation="Horizontal">
                    <StackPanel Width="400" Margin="0,0,12,8">
                        <TextBlock Text="{Binding L[settings.appLogs.directory]}" FontSize="11" Foreground="#B7C1CC" Margin="0,0,0,4" />
                        <TextBox Text="{Binding AppLogDirectory}" Watermark="{Binding L[settings.appLogs.directory.defaultWatermark]}" />
                    </StackPanel>
                    <StackPanel Width="160" Margin="0,0,12,8">
                        <TextBlock Text="{Binding L[settings.appLogs.format]}" FontSize="11" Foreground="#B7C1CC" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding AppLogFormats}" SelectedItem="{Binding AppLogFormat}" HorizontalAlignment="Stretch" />
                    </StackPanel>
                    <StackPanel Width="160" Margin="0,0,12,8">
                        <TextBlock Text="{Binding L[settings.appLogs.minLevel]}" FontSize="11" Foreground="#B7C1CC" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding AppLogLevels}" SelectedItem="{Binding AppLogMinLevel}" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </WrapPanel>
            </StackPanel>

            <!-- Notifications -->
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding L[settings.section.notifications]}" FontSize="13" FontWeight="Bold" Foreground="#E6EDF3" />
                <WrapPanel Orientation="Horizontal">
                    <CheckBox Content="{Binding L[settings.notifications.storage]}" IsChecked="{Binding NotificationsStorageAlertsEnabled}" Margin="0,0,16,8" />
                    <CheckBox Content="{Binding L[settings.notifications.connection]}" IsChecked="{Binding NotificationsConnectionAlertsEnabled}" Margin="0,0,16,8" />
                    <CheckBox Content="{Binding L[settings.notifications.export]}" IsChecked="{Binding NotificationsExportAlertsEnabled}" Margin="0,0,16,8" />
                    <StackPanel Width="160" Margin="0,0,12,8">
                        <TextBlock Text="{Binding L[settings.notifications.retentionDays]}" FontSize="11" Foreground="#B7C1CC" Margin="0,0,0,4" />
                        <NumericUpDown Minimum="1" Maximum="365" Value="{Binding NotificationsRetentionDays}" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </WrapPanel>
            </StackPanel>

            <!-- Connection -->
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding L[settings.section.connection]}" FontSize="13" FontWeight="Bold" Foreground="#E6EDF3" />
                <WrapPanel Orientation="Horizontal">
                    <StackPanel Width="180" Margin="0,0,12,8">
                        <TextBlock Height="16" Margin="0,0,0,4" />
                        <CheckBox Content="{Binding L[settings.connection.defaultAddCr]}" IsChecked="{Binding ConnectionDefaultAddCr}" />
                    </StackPanel>
                    <StackPanel Width="180" Margin="0,0,12,8">
                        <TextBlock Height="16" Margin="0,0,0,4" />
                        <CheckBox Content="{Binding L[settings.connection.defaultAddLf]}" IsChecked="{Binding ConnectionDefaultAddLf}" />
                    </StackPanel>
                </WrapPanel>
            </StackPanel>

            <!-- Display -->
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding L[settings.section.display]}" FontSize="13" FontWeight="Bold" Foreground="#E6EDF3" />
                <WrapPanel Orientation="Horizontal">
                    <StackPanel Width="200" Margin="0,0,12,8">
                        <TextBlock Text="{Binding L[settings.display.timestampFormat]}" FontSize="11" Foreground="#B7C1CC" Margin="0,0,0,4" />
                        <TextBox Text="{Binding DisplayTimestampFormat}" />
                    </StackPanel>
                    <StackPanel Width="180" Margin="0,0,12,8">
                        <TextBlock Height="16" Margin="0,0,0,4" />
                        <CheckBox Content="{Binding L[settings.display.autoScroll]}" IsChecked="{Binding DisplayAutoScroll}" />
                    </StackPanel>
                </WrapPanel>
                <WrapPanel Orientation="Horizontal">
                    <StackPanel Width="320" Margin="0,0,12,8">
                        <TextBlock Text="{Binding L[settings.display.uiFontFamily]}" FontSize="11" Foreground="#B7C1CC" Margin="0,0,0,4" />
                        <TextBox Text="{Binding DisplayFontFamily}" />
                    </StackPanel>
                    <StackPanel Width="320" Margin="0,0,12,8">
                        <TextBlock Text="{Binding L[settings.display.messageFontFamily]}" FontSize="11" Foreground="#B7C1CC" Margin="0,0,0,4" />
                        <TextBox Text="{Binding MessageFontFamily}" />
                    </StackPanel>
                    <StackPanel Width="120" Margin="0,0,12,8">
                        <TextBlock Text="{Binding L[settings.display.messageFontSize]}" FontSize="11" Foreground="#B7C1CC" Margin="0,0,0,4" />
                        <NumericUpDown Minimum="8" Maximum="24" Value="{Binding MessageFontSize}" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </WrapPanel>
            </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Storage settings page -->
            <ScrollViewer IsVisible="{Binding IsStorageSettingsSelected}">
                <StackPanel Spacing="16" Margin="20">
                    <TextBlock Text="{Binding L[settings.storage.title]}" FontSize="13" FontWeight="Bold" Foreground="#E6EDF3" />

                    <Border Background="#1B242A" BorderBrush="#25303A" BorderThickness="1" CornerRadius="4" Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding L[settings.storage.behavior.title]}" FontSize="12" FontWeight="SemiBold" Foreground="#E6EDF3" />
                            <TextBlock Text="{Binding L[settings.storage.behavior.description]}"
                                       FontSize="11"
                                       Foreground="#B7C1CC"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding L[settings.storage.status.title]}" FontSize="12" FontWeight="SemiBold" Foreground="#E6EDF3" />
                        <WrapPanel Orientation="Horizontal">
                            <StackPanel Width="220" Margin="0,0,12,8">
                                <TextBlock Text="{Binding L[settings.storage.calibration]}" FontSize="11" Foreground="#B7C1CC" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding StorageCalibrationStatus}" FontSize="12" Foreground="#E6EDF3" />
                            </StackPanel>
                            <StackPanel Width="220" Margin="0,0,12,8">
                                <TextBlock Text="{Binding L[settings.storage.health]}" FontSize="11" Foreground="#B7C1CC" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding StorageHealthStatus}" FontSize="12" Foreground="#E6EDF3" />
                            </StackPanel>
                            <StackPanel Width="160" Margin="0,0,12,8">
                                <TextBlock Text="{Binding L[settings.storage.usage]}" FontSize="11" Foreground="#B7C1CC" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding StorageSpoolUsage}" FontSize="12" Foreground="#E6EDF3" />
                            </StackPanel>
                        </WrapPanel>
                        <Button Content="{Binding L[settings.storage.refresh]}" Width="120" Click="OnRefreshStorageClick" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding L[settings.storage.limits.title]}" FontSize="12" FontWeight="SemiBold" Foreground="#E6EDF3" />
                        <TextBlock Text="{Binding L[settings.storage.limits.description]}"
                                   FontSize="11"
                                   Foreground="#B7C1CC"
                                   TextWrapping="Wrap" />
                        <WrapPanel Orientation="Horizontal">
                            <StackPanel Width="220" Margin="0,0,12,8">
                                <TextBlock Text="{Binding L[settings.storage.limit.global]}" FontSize="11" Foreground="#B7C1CC" Margin="0,0,0,4" />
                                <NumericUpDown Minimum="1" Maximum="1048576" Value="{Binding StorageGlobalLimitMb}" HorizontalAlignment="Stretch" />
                            </StackPanel>
                            <StackPanel Width="220" Margin="0,0,12,8">
                                <TextBlock Text="{Binding L[settings.storage.limit.session]}" FontSize="11" Foreground="#B7C1CC" Margin="0,0,0,4" />
                                <NumericUpDown Minimum="1" Maximum="1048576" Value="{Binding StoragePerSessionLimitMb}" HorizontalAlignment="Stretch" />
                            </StackPanel>
                            <StackPanel Width="220" Margin="0,0,12,8">
                                <TextBlock Text="{Binding L[settings.storage.limit.segment]}" FontSize="11" Foreground="#B7C1CC" Margin="0,0,0,4" />
                                <NumericUpDown Minimum="1" Maximum="1048576" Value="{Binding StorageSegmentLimitMb}" HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding L[settings.storage.paths.title]}" FontSize="12" FontWeight="SemiBold" Foreground="#E6EDF3" />
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding L[settings.storage.path.data]}" FontSize="11" Foreground="#B7C1CC" />
                            <TextBox Text="{Binding StorageDataDirectory}" IsReadOnly="True" />
                            <Button Content="{Binding L[settings.storage.openDataDirectory]}" Width="180" Click="OnOpenDataDirectoryClick" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding L[settings.storage.path.spool]}" FontSize="11" Foreground="#B7C1CC" />
                            <TextBox Text="{Binding StorageSpoolDirectory}" IsReadOnly="True" />
                            <Button Content="{Binding L[settings.storage.openSpoolDirectory]}" Width="180" Click="OnOpenSpoolDirectoryClick" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Plugin manager page -->
            <ScrollViewer IsVisible="{Binding IsPluginManagerSelected}">
                <StackPanel Spacing="12" Margin="20">
                    <TextBlock Text="{Binding SelectedNavigationEntry.Title}" FontSize="13" FontWeight="Bold" Foreground="#E6EDF3" />
                    <views:PluginManagerView DataContext="{Binding PluginManager}" />
                </StackPanel>
            </ScrollViewer>

            <!-- Plugin settings page -->
            <ScrollViewer IsVisible="{Binding IsPluginSettingsSelected}">
                <StackPanel Spacing="12" Margin="20">
                    <TextBlock Text="{Binding SelectedNavigationEntry.Title}" FontSize="13" FontWeight="Bold" Foreground="#E6EDF3" />
                    <ContentControl Content="{Binding PluginSettingsPanel}" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
