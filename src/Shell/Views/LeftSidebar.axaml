<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ComCross.Shell.ViewModels"
             xmlns:views="clr-namespace:ComCross.Shell.Views"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="800"
             x:Class="ComCross.Shell.Views.LeftSidebar"
             x:DataType="vm:LeftSidebarViewModel"
             x:Name="LeftSidebarRoot">
    
    <UserControl.Resources>
        <Geometry x:Key="IconChevronRight">M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z</Geometry>
        <Geometry x:Key="IconChevronDown">M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z</Geometry>
        <Geometry x:Key="IconPlusPanel">M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z</Geometry>
    </UserControl.Resources>

    <UserControl.Styles>
        <StyleInclude Source="avares://ComCross.Shell/Animations/SidebarAnimations.axaml" />
        <Style Selector="Button.activity-tab">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="{StaticResource Text2Brush}" />
            <Setter Property="RenderTransform" Value="translateY(0px)" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.activity-tab:pointerover:not(.active)">
            <Setter Property="Foreground" Value="{StaticResource Text0Brush}" />
            <Setter Property="RenderTransform" Value="translateY(-1px)" />
        </Style>
        <Style Selector="Button.activity-tab.active">
            <Setter Property="Foreground" Value="{StaticResource Text0Brush}" />
        </Style>
        <Style Selector="Button.activity-tab Path">
            <Setter Property="Stroke" Value="{StaticResource Text2Brush}" />
            <Setter Property="StrokeThickness" Value="1.8" />
            <Setter Property="StrokeLineCap" Value="Round" />
            <Setter Property="StrokeJoin" Value="Round" />
            <Setter Property="Stretch" Value="Uniform" />
        </Style>
        <Style Selector="Button.activity-tab:pointerover:not(.active) Path">
            <Setter Property="Stroke" Value="{StaticResource Text0Brush}" />
        </Style>
        <Style Selector="Button.activity-tab.active Path">
            <Setter Property="Stroke" Value="{StaticResource AccentBlueBrush}" />
        </Style>
        <Style Selector="Button.sidebar-icon-action">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{StaticResource Bg2Brush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
        <Style Selector="Button.sidebar-icon-action:pointerover">
            <Setter Property="Background" Value="{StaticResource BgInteractiveHoverBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
        </Style>
        <Style Selector="Button.sidebar-icon-action:disabled">
            <Setter Property="Opacity" Value="0.45" />
        </Style>
        <Style Selector="Button.session-row-action">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.session-row-action:pointerover">
            <Setter Property="Background" Value="{StaticResource BgInteractiveHoverBrush}" />
        </Style>
    </UserControl.Styles>

    <Border Background="{StaticResource Bg0Brush}" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
        <Grid ColumnDefinitions="52,*" Margin="0">
            <Border Grid.Column="0" Background="{StaticResource Bg0Brush}" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
                <Grid RowDefinitions="*">
                    <StackPanel Grid.Row="0" Margin="0,12,0,0" Spacing="8">
                        <Button Classes="activity-tab"
                                Command="{Binding ShowSessionsSectionCommand}"
                                Classes.active="{Binding IsSessionsSection}"
                                ToolTip.Tip="{Binding SessionsTabLabel}">
                            <Grid Width="36" Height="42">
                                <Border Width="3"
                                        Height="22"
                                        Background="{StaticResource AccentBlueBrush}"
                                        CornerRadius="0,3,3,0"
                                        HorizontalAlignment="Left"
                                        IsVisible="{Binding IsSessionsSection}" />
                                <Grid Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border Width="16"
                                            Height="2.8"
                                            Background="{StaticResource AccentBlueBrush}"
                                            CornerRadius="2"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Top"
                                            Margin="3,4,0,0" />
                                    <Border Width="16"
                                            Height="2.8"
                                            Background="{StaticResource AccentBlueBrush}"
                                            CornerRadius="2"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="3,0,0,0" />
                                    <Border Width="16"
                                            Height="2.8"
                                            Background="{StaticResource AccentBlueBrush}"
                                            CornerRadius="2"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Bottom"
                                            Margin="3,0,0,4" />
                                    <Ellipse Width="3"
                                             Height="3"
                                             Fill="{StaticResource AccentBlueBrush}"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Top"
                                             Margin="2,4,0,0" />
                                    <Ellipse Width="3"
                                             Height="3"
                                             Fill="{StaticResource AccentBlueBrush}"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Center"
                                             Margin="2,0,0,0" />
                                    <Ellipse Width="3"
                                             Height="3"
                                             Fill="{StaticResource AccentBlueBrush}"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Bottom"
                                             Margin="2,0,0,4" />
                                </Grid>
                            </Grid>
                        </Button>

                        <Button Classes="activity-tab"
                                Command="{Binding ShowQuickCreateSectionCommand}"
                                Classes.active="{Binding IsQuickCreateSection}"
                                ToolTip.Tip="{Binding QuickCreateTabLabel}">
                            <Grid Width="36" Height="42">
                                <Border Width="3"
                                        Height="22"
                                        Background="{StaticResource AccentBlueBrush}"
                                        CornerRadius="0,3,3,0"
                                        HorizontalAlignment="Left"
                                        IsVisible="{Binding IsQuickCreateSection}" />
                                <Path Data="{StaticResource PlusIcon}"
                                      Width="18"
                                      Height="18"
                                      Stretch="Uniform"
                                      Stroke="{StaticResource AccentBlueBrush}"
                                      StrokeThickness="1.9"
                                      StrokeLineCap="Round"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource Bg1Brush}">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0"
                            Background="{StaticResource Bg1Brush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="16,14,16,12"
                            IsVisible="{Binding IsQuickCreateSection}">
                        <Grid ColumnDefinitions="*">
                            <StackPanel Spacing="3">
                                <TextBlock Text="{Binding QuickCreateTitle}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#E8EEF4"
                                           IsVisible="{Binding IsQuickCreateSection}" />
                                <TextBlock Text="{Binding QuickCreateHint}"
                                           FontSize="11"
                                           Foreground="#81909D"
                                           TextWrapping="Wrap"
                                           IsVisible="{Binding IsQuickCreateSection}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <ScrollViewer IsVisible="{Binding IsQuickCreateSection}" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="14" Margin="16">
                                <Border Background="{StaticResource BgCardBrush}"
                                        BorderBrush="{StaticResource BorderSubtleBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12">
                                    <views:BusAdapterSelector DataContext="{Binding QuickCreateSelectorViewModel}" />
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Grid IsVisible="{Binding IsSessionsSection}" RowDefinitions="Auto,*,60">
                            <Border Grid.Row="0"
                                    Background="{StaticResource Bg1Brush}"
                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="16,12">
                                <StackPanel Spacing="8">
                                    <Border Background="{StaticResource BgCardBrush}"
                                            BorderBrush="{StaticResource BorderSubtleBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12"
                                            IsVisible="{Binding !HasActiveSession}">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding CurrentSessionEmptyTitle}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource Text0Brush}" />
                                            <TextBlock Text="{Binding CurrentSessionEmptyHint}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource Text2Brush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Spacing="8"
                                                IsVisible="{Binding HasActiveSession}">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="8"
                                                        VerticalAlignment="Center">
                                                <Ellipse Width="6"
                                                         Height="6"
                                                         Fill="{StaticResource AccentCyanBrush}"
                                                         VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding CurrentSessionName}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource Text0Brush}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        Spacing="10"
                                                        VerticalAlignment="Center">
                                                <Button Classes="prototype-plain prototype-lift"
                                                        Padding="0"
                                                        Click="OnSessionConnectionParametersClick">
                                                    <TextBlock Text="连接参数"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentBlueBrush}"
                                                               VerticalAlignment="Center" />
                                                </Button>
                                                <Button Classes="prototype-plain prototype-lift"
                                                        Width="22"
                                                        Height="22"
                                                        Padding="0"
                                                        Click="OnSessionSettingsClick">
                                                    <Path Classes="prototype-icon"
                                                          Data="{StaticResource InfoIcon}"
                                                          Width="13"
                                                          Height="13"
                                                          Stroke="{StaticResource Text2Brush}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Text="{Binding CurrentSessionEndpoint}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource Text2Brush}"
                                                   FontFamily="JetBrains Mono, Consolas, monospace" />

                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <TextBlock FontSize="11" Foreground="{StaticResource AccentCyanBrush}">
                                                <Run Text="RX: " />
                                                <Run Text="{Binding CurrentSessionRxBytes}" />
                                            </TextBlock>
                                            <TextBlock FontSize="11" Foreground="{StaticResource AccentBlueBrush}">
                                                <Run Text="TX: " />
                                                <Run Text="{Binding CurrentSessionTxBytes}" />
                                            </TextBlock>
                                        </StackPanel>

                                        <Button Content="断开连接"
                                                Command="{Binding BusAdapterSelectorViewModel.DisconnectCommand}"
                                                IsVisible="{Binding IsConnected}" />
                                        <Button Content="重新连接"
                                                Classes="prototype-action-button primary compact"
                                                Command="{Binding DirectReconnectCommand}"
                                                IsVisible="{Binding CanReconnectActiveSession}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <ScrollViewer Grid.Row="1"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="4"
                                            Margin="8,14,8,8"
                                            HorizontalAlignment="Stretch">
                                    <ListBox ItemsSource="{Binding SessionItems}"
                                             SelectedItem="{Binding SelectedSessionItem}"
                                             SelectionMode="Single"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                        <ListBox.Styles>
                                            <Style Selector="ListBoxItem">
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0" />
                                                <Setter Property="Background" Value="Transparent" />
                                            </Style>
                                        </ListBox.Styles>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:SessionListItemViewModel">
                                                <Grid Margin="0,2,0,4">
                                                    <Grid IsVisible="{Binding IsGroupSession}"
                                                          HorizontalAlignment="Stretch">
                                                        <Grid ColumnDefinitions="28,*"
                                                              HorizontalAlignment="Stretch">
                                                            <Button Grid.Column="0"
                                                                    Classes="prototype-plain"
                                                                    Width="28"
                                                                    Height="40"
                                                                    IsVisible="{Binding ShowChevron}"
                                                                    Click="OnToggleParentCollapseClick">
                                                                <Border Width="28"
                                                                        Height="40"
                                                                        Background="Transparent"
                                                                        CornerRadius="6">
                                                                    <Panel>
                                                                        <Path Classes="prototype-icon"
                                                                                  Data="{StaticResource ChevronRightIcon}"
                                                                                  Width="13"
                                                                                  Height="13"
                                                                                  Stroke="{StaticResource Text2Brush}"
                                                                                  HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"
                                                                                  IsVisible="{Binding IsCollapsed}" />
                                                                        <Path Classes="prototype-icon"
                                                                                  Data="{StaticResource ChevronDownIcon}"
                                                                                  Width="13"
                                                                                  Height="13"
                                                                                  Stroke="{StaticResource Text2Brush}"
                                                                                  HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"
                                                                                  IsVisible="{Binding !IsCollapsed}" />
                                                                    </Panel>
                                                                </Border>
                                                            </Button>

                                                            <Border Grid.Column="1"
                                                                    MinHeight="42"
                                                                    HorizontalAlignment="Stretch"
                                                                    Padding="10,6"
                                                                    Classes="prototype-interactive-surface interactive"
                                                                    Classes.selected="{Binding $parent[ListBoxItem].IsSelected}">

                                                                <Grid ColumnDefinitions="16,*,Auto,Auto,Auto"
                                                                      VerticalAlignment="Center">
                                                                    <Path Classes="prototype-icon"
                                                                          Data="{Binding IconGeometry}"
                                                                          Width="16"
                                                                          Height="16"
                                                                          Stroke="{StaticResource AccentCyanBrush}"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center" />

                                                                    <StackPanel Grid.Column="1"
                                                                                Margin="8,0,0,0"
                                                                                Spacing="2"
                                                                                VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding DisplayName}"
                                                                                   FontFamily="JetBrains Mono, Consolas, monospace"
                                                                                   FontSize="11"
                                                                                   Foreground="{StaticResource Text0Brush}"
                                                                                   TextTrimming="CharacterEllipsis" />
                                                                        <TextBlock Text="{Binding Subtitle}"
                                                                                   FontFamily="JetBrains Mono, Consolas, monospace"
                                                                                   FontSize="9"
                                                                                   Foreground="{StaticResource Text2Brush}"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   IsVisible="{Binding HasSubtitle}" />
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="2"
                                                                               Text="{Binding ChildSessionCount}"
                                                                               Margin="10,0,0,0"
                                                                               FontSize="10"
                                                                               Foreground="{StaticResource Text2Brush}"
                                                                               VerticalAlignment="Center" />
                                                                    <Button Grid.Column="3"
                                                                            Classes="session-row-action"
                                                                            Margin="6,0,0,0"
                                                                            Click="OnRenameSessionClick"
                                                                            ToolTip.Tip="{Binding L[session.menu.rename]}">
                                                                        <Path Classes="prototype-icon"
                                                                              Data="{StaticResource PencilIcon}"
                                                                              Width="12"
                                                                              Height="12"
                                                                              Stroke="{StaticResource Text2Brush}"
                                                                              HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center" />
                                                                    </Button>
                                                                    <Button Grid.Column="4"
                                                                            Classes="session-row-action"
                                                                            Click="OnDeleteSessionClick"
                                                                            ToolTip.Tip="{Binding L[session.menu.delete]}">
                                                                        <Path Classes="prototype-icon"
                                                                              Data="{StaticResource Trash2Icon}"
                                                                              Width="12"
                                                                              Height="12"
                                                                              Stroke="{StaticResource Text2Brush}"
                                                                              HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center" />
                                                                    </Button>
                                                                </Grid>
                                                            </Border>
                                                        </Grid>
                                                    </Grid>

                                                    <Grid IsVisible="{Binding IsLeafSession}"
                                                          HorizontalAlignment="Stretch">
                                                        <Grid IsVisible="{Binding HasParent}"
                                                              ColumnDefinitions="28,*"
                                                              HorizontalAlignment="Stretch">
                                                            <Grid Grid.Column="0"
                                                                  Height="42"
                                                                  HorizontalAlignment="Stretch">
                                                                <Border Width="1"
                                                                        Background="{StaticResource BorderStrongBrush}"
                                                                        Opacity="0.55"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Stretch" />
                                                                <Border Width="12"
                                                                        Height="1"
                                                                        Background="{StaticResource BorderStrongBrush}"
                                                                        Opacity="0.7"
                                                                        HorizontalAlignment="Right"
                                                                        VerticalAlignment="Center"
                                                                        Margin="0,0,2,0" />
                                                            </Grid>

                                                            <Border Grid.Column="1"
                                                                    MinHeight="40"
                                                                    Padding="10,6"
                                                                    Classes="prototype-interactive-surface interactive"
                                                                    Classes.selected="{Binding $parent[ListBoxItem].IsSelected}">

                                                                <Grid ColumnDefinitions="16,*,Auto,Auto"
                                                                      VerticalAlignment="Center">
                                                                    <Path Classes="prototype-icon"
                                                                          Data="{Binding IconGeometry}"
                                                                          Width="16"
                                                                          Height="16"
                                                                          Stroke="{StaticResource AccentBlueBrush}"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center" />

                                                                    <StackPanel Grid.Column="1"
                                                                                Spacing="2"
                                                                                VerticalAlignment="Center">
                                                                        <StackPanel Orientation="Horizontal"
                                                                                    Spacing="8">
                                                                            <Ellipse Width="4"
                                                                                     Height="4"
                                                                                     Fill="{Binding Status, Converter={StaticResource StatusColorConverter}}"
                                                                                     VerticalAlignment="Center" />
                                                                            <TextBlock Text="{Binding DisplayName}"
                                                                                       FontSize="11"
                                                                                       Foreground="{StaticResource Text0Brush}"
                                                                                       VerticalAlignment="Center"
                                                                                       TextTrimming="CharacterEllipsis" />
                                                                        </StackPanel>
                                                                        <TextBlock Text="{Binding Subtitle}"
                                                                                   Margin="12,0,0,0"
                                                                                   FontFamily="JetBrains Mono, Consolas, monospace"
                                                                                   FontSize="9"
                                                                                   Foreground="{StaticResource Text2Brush}"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   IsVisible="{Binding HasSubtitle}" />
                                                                    </StackPanel>
                                                                    <Button Grid.Column="2"
                                                                            Classes="session-row-action"
                                                                            Margin="6,0,0,0"
                                                                            Click="OnRenameSessionClick"
                                                                            ToolTip.Tip="{Binding L[session.menu.rename]}">
                                                                        <Path Classes="prototype-icon"
                                                                              Data="{StaticResource PencilIcon}"
                                                                              Width="12"
                                                                              Height="12"
                                                                              Stroke="{StaticResource Text2Brush}"
                                                                              HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center" />
                                                                    </Button>
                                                                    <Button Grid.Column="3"
                                                                            Classes="session-row-action"
                                                                            Click="OnDeleteSessionClick"
                                                                            ToolTip.Tip="{Binding L[session.menu.delete]}">
                                                                        <Path Classes="prototype-icon"
                                                                              Data="{StaticResource Trash2Icon}"
                                                                              Width="12"
                                                                              Height="12"
                                                                              Stroke="{StaticResource Text2Brush}"
                                                                              HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center" />
                                                                    </Button>
                                                                </Grid>
                                                            </Border>
                                                        </Grid>

                                                        <Border IsVisible="{Binding !HasParent}"
                                                                MinHeight="40"
                                                                Padding="10,6"
                                                                Classes="prototype-interactive-surface interactive"
                                                                Classes.selected="{Binding $parent[ListBoxItem].IsSelected}">

                                                            <Grid ColumnDefinitions="16,*,Auto,Auto"
                                                                  VerticalAlignment="Center">
                                                                <Path Classes="prototype-icon"
                                                                      Data="{Binding IconGeometry}"
                                                                      Width="16"
                                                                      Height="16"
                                                                      Stroke="{StaticResource AccentBlueBrush}"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />

                                                                <StackPanel Grid.Column="1"
                                                                            Spacing="2"
                                                                            VerticalAlignment="Center">
                                                                    <StackPanel Orientation="Horizontal"
                                                                                Spacing="8">
                                                                        <Ellipse Width="4"
                                                                                 Height="4"
                                                                                 Fill="{Binding Status, Converter={StaticResource StatusColorConverter}}"
                                                                                 VerticalAlignment="Center" />
                                                                        <TextBlock Text="{Binding DisplayName}"
                                                                                   FontSize="11"
                                                                                   Foreground="{StaticResource Text0Brush}"
                                                                                   VerticalAlignment="Center"
                                                                                   TextTrimming="CharacterEllipsis" />
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding Subtitle}"
                                                                               Margin="12,0,0,0"
                                                                               FontFamily="JetBrains Mono, Consolas, monospace"
                                                                               FontSize="9"
                                                                               Foreground="{StaticResource Text2Brush}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               IsVisible="{Binding HasSubtitle}" />
                                                                </StackPanel>
                                                                <Button Grid.Column="2"
                                                                        Classes="session-row-action"
                                                                        Margin="6,0,0,0"
                                                                        Click="OnRenameSessionClick"
                                                                        ToolTip.Tip="{Binding L[session.menu.rename]}">
                                                                    <Path Classes="prototype-icon"
                                                                          Data="{StaticResource PencilIcon}"
                                                                          Width="12"
                                                                          Height="12"
                                                                          Stroke="{StaticResource Text2Brush}"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center" />
                                                                </Button>
                                                                <Button Grid.Column="3"
                                                                        Classes="session-row-action"
                                                                        Click="OnDeleteSessionClick"
                                                                        ToolTip.Tip="{Binding L[session.menu.delete]}">
                                                                    <Path Classes="prototype-icon"
                                                                          Data="{StaticResource Trash2Icon}"
                                                                          Width="12"
                                                                          Height="12"
                                                                          Stroke="{StaticResource Text2Brush}"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center" />
                                                                </Button>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </ScrollViewer>

                            <Border Grid.Row="2"
                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="16,10">
                                <Button Classes="prototype-plain"
                                        Command="{Binding ShowQuickCreateSectionCommand}"
                                        HorizontalAlignment="Stretch">
                                    <Border Height="40"
                                            CornerRadius="8"
                                            Background="{StaticResource PrimaryButtonBrush}">
                                        <Grid ColumnDefinitions="18,Auto"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center">
                                            <Path Data="{StaticResource ZapIcon}"
                                                  Stroke="{StaticResource WhiteBrush}"
                                                  StrokeThickness="1.8"
                                                  Width="16"
                                                  Height="16"
                                                  Stretch="Uniform"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Margin="6,0,0,0"
                                                       Text="快速连接"
                                                       Foreground="{StaticResource WhiteBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </Button>
                            </Border>
                        </Grid>
            </Grid>
        </Grid>
        </Border>
        </Grid>
    </Border>
</UserControl>
