<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ComCross.Shell.ViewModels"
             xmlns:views="clr-namespace:ComCross.Shell.Views"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="800"
             x:Class="ComCross.Shell.Views.LeftSidebar"
             x:DataType="vm:LeftSidebarViewModel"
             x:Name="LeftSidebarRoot">
    
            <UserControl.Resources>
        <Geometry x:Key="IconChevronRight">M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z</Geometry>
        <Geometry x:Key="IconChevronDown">M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z</Geometry>
        <Geometry x:Key="IconWifi">M12,2C6.48,2 2,6.48 2,12C2,17.52 6.48,22 12,22C17.52,22 22,17.52 22,12C22,6.48 17.52,2 12,2ZM12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20ZM12,6C8.69,6 6,8.69 6,12C6,15.31 8.69,18 12,18C15.31,18 18,15.31 18,12C18,8.69 15.31,6 12,6ZM12,16C9.79,16 8,14.21 8,12C8,9.79 9.79,8 12,8C14.21,8 16,9.79 16,12C16,14.21 14.21,16 12,16Z</Geometry>
    </UserControl.Resources>

    <Border Background="#141B1F" BorderBrush="#25303A" BorderThickness="0,0,1,0">
        <Grid ColumnDefinitions="64,*" Margin="0">
            <Border Grid.Column="0" Background="#10161B" BorderBrush="#25303A" BorderThickness="0,0,1,0">
                <StackPanel Margin="8" Spacing="8">
                    <Button Command="{Binding ShowQuickCreateSectionCommand}"
                            Classes.active="{Binding IsQuickCreateSection}"
                            ToolTip.Tip="{Binding QuickCreateTabLabel}"
                            Padding="8,12">
                        <Button.Styles>
                            <Style Selector="Button">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="#25303A" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="CornerRadius" Value="10" />
                            </Style>
                            <Style Selector="Button.active">
                                <Setter Property="Background" Value="#173149" />
                                <Setter Property="BorderBrush" Value="#2F6F9B" />
                            </Style>
                            <Style Selector="Button:pointerover">
                                <Setter Property="Background" Value="#182128" />
                            </Style>
                        </Button.Styles>
                        <TextBlock Text="{Binding QuickCreateTabLabel}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                    </Button>

                    <Button Command="{Binding ShowSessionsSectionCommand}"
                            Classes.active="{Binding IsSessionsSection}"
                            ToolTip.Tip="{Binding SessionsTabLabel}"
                            Padding="8,12">
                        <Button.Styles>
                            <Style Selector="Button">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="#25303A" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="CornerRadius" Value="10" />
                            </Style>
                            <Style Selector="Button.active">
                                <Setter Property="Background" Value="#173149" />
                                <Setter Property="BorderBrush" Value="#2F6F9B" />
                            </Style>
                            <Style Selector="Button:pointerover">
                                <Setter Property="Background" Value="#182128" />
                            </Style>
                        </Button.Styles>
                        <TextBlock Text="{Binding SessionsTabLabel}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                    </Button>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Margin="16">
                <ScrollViewer IsVisible="{Binding IsQuickCreateSection}" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding QuickCreateTitle}"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="#E6EDF3" />
                            <TextBlock Text="{Binding QuickCreateHint}"
                                       FontSize="11"
                                       Foreground="#87909B"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <views:BusAdapterSelector DataContext="{Binding QuickCreateSelectorViewModel}" />
                    </StackPanel>
                </ScrollViewer>

                <Grid IsVisible="{Binding IsSessionsSection}" RowDefinitions="Auto,Auto,*">
                    <Grid Grid.Row="0" IsVisible="{Binding ShowSimpleSessionCard}">
                        <Border Background="#162026"
                                BorderBrush="#25303A"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="{Binding CurrentSessionTitle}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#87909B" />

                                <StackPanel Spacing="4" IsVisible="{Binding HasActiveSession}">
                                    <TextBlock Text="{Binding ActiveSessionNameText}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#E6EDF3" />
                                    <TextBlock Text="{Binding ActiveSessionEndpointText}"
                                               FontSize="11"
                                               Foreground="#93A0AC"
                                               FontFamily="JetBrains Mono, Consolas, monospace"
                                               IsVisible="{Binding ActiveSessionEndpointText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                </StackPanel>

                                <StackPanel Spacing="4" IsVisible="{Binding !HasActiveSession}">
                                    <TextBlock Text="{Binding CurrentSessionEmptyTitle}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#E6EDF3" />
                                    <TextBlock Text="{Binding CurrentSessionEmptyHint}"
                                               FontSize="11"
                                               Foreground="#87909B"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding HasActiveSession}">
                                    <Border Background="#11181D"
                                            BorderBrush="#25303A"
                                            BorderThickness="1"
                                            CornerRadius="999"
                                            Padding="8,2">
                                        <TextBlock Text="{Binding ActiveSessionStatusText}"
                                                   FontSize="10"
                                                   Foreground="#B7C1CC" />
                                    </Border>
                                    <Border Background="#141F27"
                                            BorderBrush="#25303A"
                                            BorderThickness="1"
                                            CornerRadius="999"
                                            Padding="8,2">
                                        <TextBlock Text="{Binding ActiveSessionTypeText}"
                                                   FontSize="10"
                                                   Foreground="#BDE3FF" />
                                    </Border>
                                </StackPanel>

                                <Grid ColumnDefinitions="*,*" IsVisible="{Binding HasActiveSession}">
                                    <Button Grid.Column="0"
                                            Content="{Binding L[menu.disconnect]}"
                                            Command="{Binding DisconnectActiveSessionCommand}"
                                            IsEnabled="{Binding CanDisconnectActiveSession}"
                                            Margin="0,0,4,0" />
                                    <Button Grid.Column="1"
                                            Content="{Binding L[session.menu.delete]}"
                                            Command="{Binding DeleteActiveSessionCommand}"
                                            IsEnabled="{Binding CanDeleteActiveSession}"
                                            Margin="4,0,0,0" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="0" IsVisible="{Binding ShowNetworkSessionPanel}">
                        <views:BusAdapterSelector DataContext="{Binding BusAdapterSelectorViewModel}" />
                    </Grid>

                    <Separator Grid.Row="1" Background="#25303A" Height="1" Margin="0,16,0,16" />

                    <Grid Grid.Row="2" RowDefinitions="Auto,*">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding L[sidebar.sessions]}" 
                                       FontSize="11" 
                                       FontWeight="Bold" 
                                       Foreground="#87909B"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Content="＋"
                                    FontSize="16"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="8,4"
                                    ToolTip.Tip="{Binding L[sidebar.newSession]}"
                                    Command="{Binding ShowQuickCreateSectionCommand}">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover">
                                        <Setter Property="Background" Value="#1A2530" />
                                    </Style>
                                </Button.Styles>
                            </Button>
                        </Grid>

                        <ListBox ItemsSource="{Binding SessionItems}"
                                 Grid.Row="1"
                                 Margin="0,12,0,0"
                                 SelectedItem="{Binding SelectedSessionItem}" 
                                 SelectionMode="Single"
                                 Background="Transparent" 
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="CornerRadius" Value="8" />
                        </Style>

                        <!-- Default border for all session items -->
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:SessionListItemViewModel">
                            <Grid>
                                <!-- Listener Template -->
                                <Border x:Name="ListenerCard"
                                        IsVisible="{Binding IsListener}"
                                        Background="#1B242A"
                                        BorderBrush="#25303A"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="0,0,0,4"
                                        Padding="8,6">
                                    <Grid ColumnDefinitions="Auto,Auto,*,Auto" RowDefinitions="Auto,Auto">
                                        <!-- Chevron -->
                                        <Button Grid.Column="0"
                                                Grid.Row="0"
                                                Grid.RowSpan="2"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="4"
                                                Margin="-4,0,0,0"
                                                Click="OnToggleListenerCollapseClick"
                                                VerticalAlignment="Center">
                                            <Panel>
                                                <PathIcon Data="{StaticResource IconChevronRight}" 
                                                          Foreground="#87909B"
                                                          Width="12" Height="12"
                                                          IsVisible="{Binding IsCollapsed}"/>
                                                <PathIcon Data="{StaticResource IconChevronDown}" 
                                                          Foreground="#87909B"
                                                          Width="12" Height="12"
                                                          IsVisible="{Binding !IsCollapsed}"/>
                                            </Panel>
                                        </Button>

                                        <!-- Network Icon and Status -->
                                        <StackPanel Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <PathIcon Data="{StaticResource IconWifi}" 
                                                      Foreground="{Binding Status, Converter={StaticResource StatusColorConverter}}"
                                                      Width="14" Height="14" />
                                        </StackPanel>

                                        <!-- Name -->
                                        <TextBlock Grid.Column="2"
                                                   Grid.Row="0"
                                                   Text="{Binding DisplayName}" 
                                                   Foreground="#B7C1CC"
                                                   FontSize="12"
                                                   FontWeight="Medium"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0" />

                                        <TextBlock Grid.Column="2"
                                                   Grid.Row="1"
                                                   Text="{Binding ListenerSummaryText}"
                                                   Foreground="#87909B"
                                                   FontSize="10"
                                                   Margin="8,4,0,0"
                                                   IsVisible="{Binding HasListenerChildren}" />

                                        <!-- Endpoint (Right aligned) -->
                                        <TextBlock Grid.Column="3"
                                                   Grid.Row="0"
                                                   Grid.RowSpan="2"
                                                   Text="{Binding Endpoint}" 
                                                   Foreground="#87909B" 
                                                   FontSize="11" 
                                                   FontFamily="JetBrains Mono, Consolas, monospace"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>

                                <!-- Connection Template -->
                                <Border x:Name="ConnectionCard"
                                        IsVisible="{Binding IsConnection}"
                                        CornerRadius="4"
                                        Margin="0,2,0,4"
                                        Padding="0">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <!-- Connector Line area -->
                                        <Grid Grid.Column="0" IsVisible="{Binding HasParent}" Width="20">
                                            <!-- Vertical Line -->
                                            <Border Background="#25303A" Width="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="0,-12,0,-12"/> 
                                        </Grid>

                                        <!-- Main Content Card -->
                                        <Border Grid.Column="1" 
                                                Padding="10,8"
                                                CornerRadius="4"
                                                Classes.selected="{Binding $parent[ListBoxItem].IsSelected}">
                                           <Border.Styles>
                                               <Style Selector="Border.selected">
                                                   <Setter Property="Background" Value="#3AA0FF"/>
                                               </Style>
                                               <Style Selector="Border:not(.selected)">
                                                    <Setter Property="Background" Value="Transparent"/>
                                               </Style>
                                           </Border.Styles> 
                                           
                                           <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                                                <!-- Status Dot -->
                                                <Ellipse Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Width="8" Height="8" Margin="0,2,8,0" VerticalAlignment="Top">
                                                    <Ellipse.Fill>
                                                        <SolidColorBrush Color="{Binding Status, Converter={StaticResource StatusColorConverter}}" />
                                                    </Ellipse.Fill>
                                                </Ellipse>

                                                <!-- Content -->
                                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="{Binding DisplayName}" 
                                                                   Classes.selected="{Binding $parent[ListBoxItem].IsSelected}"
                                                                   FontSize="13" 
                                                                   FontWeight="SemiBold">
                                                            <TextBlock.Styles>
                                                                <Style Selector="TextBlock.selected">
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </Style>
                                                                <Style Selector="TextBlock:not(.selected)">
                                                                    <Setter Property="Foreground" Value="#E6EDF3"/>
                                                                </Style>
                                                            </TextBlock.Styles>
                                                        </TextBlock>
                                                        <Border Background="#1B242A"
                                                                BorderBrush="#25303A"
                                                                BorderThickness="1"
                                                                CornerRadius="999"
                                                                Padding="6,1"
                                                                VerticalAlignment="Center"
                                                                IsVisible="{Binding ShowConnectionBadge}">
                                                            <TextBlock Text="{Binding ConnectionBadgeText}"
                                                                       FontSize="9"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#B7C1CC" />
                                                        </Border>
                                                    </StackPanel>
                                                    
                                                    <TextBlock Text="{Binding Endpoint}" 
                                                               Classes.selected="{Binding $parent[ListBoxItem].IsSelected}"
                                                               FontSize="11" 
                                                               FontFamily="JetBrains Mono, Consolas, monospace">
                                                         <TextBlock.Styles>
                                                            <Style Selector="TextBlock.selected">
                                                                <Setter Property="Foreground" Value="White"/> 
                                                                <Setter Property="Opacity" Value="0.9"/>
                                                            </Style>
                                                            <Style Selector="TextBlock:not(.selected)">
                                                                <Setter Property="Foreground" Value="#87909B"/>
                                                            </Style>
                                                        </TextBlock.Styles>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Stats Line -->
                                                 <Grid Grid.Row="1" Grid.Column="1" Margin="0,4,0,0" IsVisible="{Binding ShowStats}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" FontSize="10" 
                                                               Classes.selected="{Binding $parent[ListBoxItem].IsSelected}"
                                                               Margin="0,0,12,0">
                                                        <TextBlock.Styles>
                                                            <Style Selector="TextBlock.selected">
                                                                <Setter Property="Foreground" Value="White"/> 
                                                                <Setter Property="Opacity" Value="0.7"/>
                                                            </Style>
                                                            <Style Selector="TextBlock:not(.selected)">
                                                                <Setter Property="Foreground" Value="#87909B"/>
                                                            </Style>
                                                        </TextBlock.Styles>
                                                        <Run Text="{Binding TxLabel}" />
                                                        <Run Text=" " />
                                                        <Run Text="{Binding TxBytes}" FontWeight="SemiBold" Foreground="#3AA0FF" />
                                                    </TextBlock>
                                                    <TextBlock Grid.Column="1" FontSize="10" 
                                                               Classes.selected="{Binding $parent[ListBoxItem].IsSelected}">
                                                         <TextBlock.Styles>
                                                            <Style Selector="TextBlock.selected">
                                                                <Setter Property="Foreground" Value="White"/> 
                                                                <Setter Property="Opacity" Value="0.7"/>
                                                            </Style>
                                                            <Style Selector="TextBlock:not(.selected)">
                                                                <Setter Property="Foreground" Value="#87909B"/>
                                                            </Style>
                                                        </TextBlock.Styles>
                                                        <Run Text="{Binding RxLabel}" />
                                                        <Run Text=" " />
                                                        <Run Text="{Binding RxBytes}" FontWeight="SemiBold" Foreground="#2CB5A9" />
                                                    </TextBlock>
                                                </Grid>

                                                <!-- Settings Button -->
                                                <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" 
                                                        Content="⚙️" 
                                                        FontSize="14"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="4"
                                                        Margin="4,0,0,0"
                                                        Click="OnSessionSettingsClick"
                                                        VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
