<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ComCross.Shell.ViewModels"
             xmlns:views="clr-namespace:ComCross.Shell.Views"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="800"
             x:Class="ComCross.Shell.Views.LeftSidebar"
             x:DataType="vm:LeftSidebarViewModel"
             x:Name="LeftSidebarRoot">
    
    <UserControl.Resources>
        <Geometry x:Key="IconChevronRight">M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z</Geometry>
        <Geometry x:Key="IconChevronDown">M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z</Geometry>
        <Geometry x:Key="IconWifi">M12,2C6.48,2 2,6.48 2,12C2,17.52 6.48,22 12,22C17.52,22 22,17.52 22,12C22,6.48 17.52,2 12,2ZM12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20ZM12,6C8.69,6 6,8.69 6,12C6,15.31 8.69,18 12,18C15.31,18 18,15.31 18,12C18,8.69 15.31,6 12,6ZM12,16C9.79,16 8,14.21 8,12C8,9.79 9.79,8 12,8C14.21,8 16,9.79 16,12C16,14.21 14.21,16 12,16Z</Geometry>
        <Geometry x:Key="IconPlusPanel">M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z</Geometry>
        <Geometry x:Key="IconSessionsPanel">M4,6C4,4.9 4.9,4 6,4H18C19.1,4 20,4.9 20,6V10C20,11.1 19.1,12 18,12H6C4.9,12 4,11.1 4,10V6ZM6,6V10H18V6H6ZM4,16C4,14.9 4.9,14 6,14H18C19.1,14 20,14.9 20,16V18C20,19.1 19.1,20 18,20H6C4.9,20 4,19.1 4,18V16ZM6,16V18H18V16H6Z</Geometry>
        <Geometry x:Key="IconReconnect">M12,5V2L8,6L12,10V7C15.31,7 18,9.69 18,13C18,16.31 15.31,19 12,19C8.69,19 6,16.31 6,13H4C4,17.42 7.58,21 12,21C16.42,21 20,17.42 20,13C20,8.58 16.42,5 12,5Z</Geometry>
        <Geometry x:Key="IconTune">M3,17V19H9V17H3ZM3,5V7H13V5H3ZM13,21V19H21V17H13V15H11V21H13ZM7,9V11H3V13H7V15H9V9H7ZM21,13V11H11V13H21ZM17,9V15H19V9H17Z</Geometry>
        <Geometry x:Key="IconBack">M20,11V13H7.83L13.42,18.59L12,20L4,12L12,4L13.42,5.41L7.83,11H20Z</Geometry>
    </UserControl.Resources>

    <UserControl.Styles>
        <StyleInclude Source="avares://ComCross.Shell/Animations/SidebarAnimations.axaml" />
        <Style Selector="Button.activity-tab">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="#70808E" />
        </Style>
        <Style Selector="Button.activity-tab:pointerover">
            <Setter Property="Background" Value="#151B21" />
            <Setter Property="Foreground" Value="#DCE6EE" />
        </Style>
        <Style Selector="Button.activity-tab.active">
            <Setter Property="Foreground" Value="#F4F8FB" />
        </Style>
        <Style Selector="Button.activity-tab PathIcon">
            <Setter Property="Foreground" Value="#70808E" />
        </Style>
        <Style Selector="Button.activity-tab:pointerover PathIcon">
            <Setter Property="Foreground" Value="#DCE6EE" />
        </Style>
        <Style Selector="Button.activity-tab.active PathIcon">
            <Setter Property="Foreground" Value="#F4F8FB" />
        </Style>
        <Style Selector="Button.sidebar-icon-action">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#1A222A" />
            <Setter Property="BorderBrush" Value="#2A343D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
        <Style Selector="Button.sidebar-icon-action:pointerover">
            <Setter Property="Background" Value="#202B34" />
            <Setter Property="BorderBrush" Value="#39505F" />
        </Style>
        <Style Selector="Button.sidebar-icon-action:disabled">
            <Setter Property="Opacity" Value="0.45" />
        </Style>
        <Style Selector="Button.sidebar-icon-action PathIcon">
            <Setter Property="Foreground" Value="#D5DEE6" />
        </Style>
    </UserControl.Styles>

    <Border Background="#11161C" BorderBrush="#28323A" BorderThickness="0,0,1,0">
        <Grid ColumnDefinitions="52,*" Margin="0">
            <Border Grid.Column="0" Background="#0D1217" BorderBrush="#202830" BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,*,Auto">
                    <Border Grid.Row="0"
                            Margin="10,10,10,8"
                            Width="32"
                            Height="32"
                            CornerRadius="10"
                            Background="#1C252D"
                            BorderBrush="#2A333C"
                            BorderThickness="1">
                        <PathIcon Data="{StaticResource IconWifi}"
                                  Width="16"
                                  Height="16"
                                  Foreground="#4FC3B5"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Row="1" Margin="0,4,0,0" Spacing="2">
                        <Button Classes="activity-tab"
                                Command="{Binding ShowQuickCreateSectionCommand}"
                                Classes.active="{Binding IsQuickCreateSection}"
                                ToolTip.Tip="{Binding QuickCreateTabLabel}">
                            <Grid Width="36" Height="42">
                                <Border Width="3"
                                        Height="22"
                                        Background="#4AA3FF"
                                        CornerRadius="0,3,3,0"
                                        HorizontalAlignment="Left"
                                        IsVisible="{Binding IsQuickCreateSection}" />
                                <PathIcon Data="{StaticResource IconPlusPanel}"
                                          Width="18"
                                          Height="18"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </Grid>
                        </Button>

                        <Button Classes="activity-tab"
                                Command="{Binding ShowSessionsSectionCommand}"
                                Classes.active="{Binding IsSessionsSection}"
                                ToolTip.Tip="{Binding SessionsTabLabel}">
                            <Grid Width="36" Height="42">
                                <Border Width="3"
                                        Height="22"
                                        Background="#4AA3FF"
                                        CornerRadius="0,3,3,0"
                                        HorizontalAlignment="Left"
                                        IsVisible="{Binding IsSessionsSection}" />
                                <PathIcon Data="{StaticResource IconSessionsPanel}"
                                          Width="18"
                                          Height="18"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="#151C22">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0"
                            Background="#161E25"
                            BorderBrush="#232D35"
                            BorderThickness="0,0,0,1"
                            Padding="16,14,16,12">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="3">
                                <TextBlock Text="{Binding QuickCreateTitle}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#E8EEF4"
                                           IsVisible="{Binding IsQuickCreateSection}" />
                                <TextBlock Text="{Binding L[sidebar.sessions]}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#E8EEF4"
                                           IsVisible="{Binding IsSessionsSection}" />
                                <TextBlock Text="{Binding QuickCreateHint}"
                                           FontSize="11"
                                           Foreground="#81909D"
                                           TextWrapping="Wrap"
                                           IsVisible="{Binding IsQuickCreateSection}" />
                                <TextBlock Text="{Binding L[sidebar.currentSession.title]}"
                                           FontSize="11"
                                           Foreground="#81909D"
                                           IsVisible="{Binding IsSessionsSection}" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Width="30"
                                    Height="30"
                                    Padding="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Background="Transparent"
                                    BorderBrush="#25303A"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    ToolTip.Tip="{Binding L[sidebar.newSession]}"
                                    Command="{Binding ShowQuickCreateSectionCommand}"
                                    IsVisible="{Binding IsSessionsSection}">
                                <PathIcon Data="{StaticResource IconPlusPanel}"
                                          Width="16"
                                          Height="16"
                                          Foreground="#C9D3DC"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </Button>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <ScrollViewer IsVisible="{Binding IsQuickCreateSection}" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="14" Margin="16">
                                <Border Background="#182229"
                                        BorderBrush="#27333C"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12">
                                    <views:BusAdapterSelector DataContext="{Binding QuickCreateSelectorViewModel}" />
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Grid IsVisible="{Binding IsSessionsSection}" RowDefinitions="Auto,Auto,*">
                            <StackPanel Grid.Row="0" Margin="16,16,16,0" Spacing="12">
                                <Border Background="#182229"
                                        BorderBrush="#27333C"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12"
                                        IsVisible="{Binding !HasActiveSession}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding CurrentSessionEmptyTitle}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#E6EDF3" />
                                        <TextBlock Text="{Binding CurrentSessionEmptyHint}"
                                                   FontSize="11"
                                                   Foreground="#87909B"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Background="#182229"
                                        BorderBrush="#27333C"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12"
                                        IsVisible="{Binding HasActiveSession}">
                                    <StackPanel Spacing="12">
                                        <Border Background="Transparent"
                                                Classes.collapsible-surface="True"
                                                Classes.expanded="{Binding ShowSessionStatusSurface}">
                                            <views:BusAdapterSelector DataContext="{Binding BusAdapterSelectorViewModel}" />
                                        </Border>

                                        <Border Background="Transparent"
                                                Classes.collapsible-surface="True"
                                                Classes.expanded="{Binding ShowReconnectParametersSurface}">
                                            <ScrollViewer MaxHeight="420"
                                                          VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled">
                                                <views:BusAdapterSelector DataContext="{Binding ReconnectEditorSelectorViewModel}" />
                                            </ScrollViewer>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Background="#141B21"
                                        BorderBrush="#27333C"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="12,10"
                                        IsVisible="{Binding CanReconnectActiveSession}">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="12"
                                                    HorizontalAlignment="Left"
                                                    IsVisible="{Binding ShowSessionStatusSurface}">
                                            <Button Classes="sidebar-icon-action"
                                                    Command="{Binding DirectReconnectCommand}"
                                                    ToolTip.Tip="{Binding DirectReconnectLabel}">
                                                <PathIcon Data="{StaticResource IconReconnect}"
                                                          Width="20"
                                                          Height="20"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                            </Button>
                                            <Button Classes="sidebar-icon-action"
                                                    Command="{Binding ShowReconnectParametersSurfaceCommand}"
                                                    ToolTip.Tip="{Binding EditReconnectLabel}">
                                                <PathIcon Data="{StaticResource IconTune}"
                                                          Width="20"
                                                          Height="20"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                            </Button>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Left"
                                                    IsVisible="{Binding ShowReconnectParametersSurface}">
                                            <Button Classes="sidebar-icon-action"
                                                    Command="{Binding ShowSessionStatusSurfaceCommand}"
                                                    ToolTip.Tip="{Binding BackToStatusLabel}">
                                                <PathIcon Data="{StaticResource IconBack}"
                                                          Width="20"
                                                          Height="20"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <Separator Grid.Row="1" Background="#25303A" Height="1" Margin="16,16,16,0" />

                            <Grid Grid.Row="2" RowDefinitions="Auto,*" Margin="16">
                                <TextBlock Grid.Row="0"
                                           Text="{Binding L[sidebar.sessions]}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#87909B"
                                           VerticalAlignment="Center" />

                                <ListBox ItemsSource="{Binding SessionItems}"
                                         Grid.Row="1"
                                         Margin="0,12,0,0"
                                         SelectedItem="{Binding SelectedSessionItem}"
                                         SelectionMode="Single"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="CornerRadius" Value="8" />
                        </Style>

                        <!-- Default border for all session items -->
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:SessionListItemViewModel">
                            <Grid>
                                <!-- Listener Template -->
                                <Border x:Name="ListenerCard"
                                        IsVisible="{Binding IsListener}"
                                        Background="#1B242A"
                                        BorderBrush="#25303A"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="0,0,0,4"
                                        Padding="8,6">
                                    <Grid ColumnDefinitions="Auto,Auto,*,Auto" RowDefinitions="Auto,Auto">
                                        <!-- Chevron -->
                                        <Button Grid.Column="0"
                                                Grid.Row="0"
                                                Grid.RowSpan="2"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="4"
                                                Margin="-4,0,0,0"
                                                Click="OnToggleListenerCollapseClick"
                                                VerticalAlignment="Center">
                                            <Panel>
                                                <PathIcon Data="{StaticResource IconChevronRight}" 
                                                          Foreground="#87909B"
                                                          Width="12" Height="12"
                                                          IsVisible="{Binding IsCollapsed}"/>
                                                <PathIcon Data="{StaticResource IconChevronDown}" 
                                                          Foreground="#87909B"
                                                          Width="12" Height="12"
                                                          IsVisible="{Binding !IsCollapsed}"/>
                                            </Panel>
                                        </Button>

                                        <!-- Network Icon and Status -->
                                        <StackPanel Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <PathIcon Data="{StaticResource IconWifi}" 
                                                      Foreground="{Binding Status, Converter={StaticResource StatusColorConverter}}"
                                                      Width="14" Height="14" />
                                        </StackPanel>

                                        <!-- Name -->
                                        <TextBlock Grid.Column="2"
                                                   Grid.Row="0"
                                                   Text="{Binding DisplayName}" 
                                                   Foreground="#B7C1CC"
                                                   FontSize="12"
                                                   FontWeight="Medium"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0" />

                                        <TextBlock Grid.Column="2"
                                                   Grid.Row="1"
                                                   Text="{Binding ListenerSummaryText}"
                                                   Foreground="#87909B"
                                                   FontSize="10"
                                                   Margin="8,4,0,0"
                                                   IsVisible="{Binding HasListenerChildren}" />

                                        <!-- Endpoint (Right aligned) -->
                                        <TextBlock Grid.Column="3"
                                                   Grid.Row="0"
                                                   Grid.RowSpan="2"
                                                   Text="{Binding Endpoint}" 
                                                   Foreground="#87909B" 
                                                   FontSize="11" 
                                                   FontFamily="JetBrains Mono, Consolas, monospace"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>

                                <!-- Connection Template -->
                                <Border x:Name="ConnectionCard"
                                        IsVisible="{Binding IsConnection}"
                                        CornerRadius="4"
                                        Margin="0,2,0,4"
                                        Padding="0">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <!-- Connector Line area -->
                                        <Grid Grid.Column="0" IsVisible="{Binding HasParent}" Width="20">
                                            <!-- Vertical Line -->
                                            <Border Background="#25303A" Width="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="0,-12,0,-12"/> 
                                        </Grid>

                                        <!-- Main Content Card -->
                                        <Border Grid.Column="1" 
                                                Padding="10,8"
                                                CornerRadius="4"
                                                Classes.selected="{Binding $parent[ListBoxItem].IsSelected}">
                                           <Border.Styles>
                                               <Style Selector="Border.selected">
                                                   <Setter Property="Background" Value="#3AA0FF"/>
                                               </Style>
                                               <Style Selector="Border:not(.selected)">
                                                    <Setter Property="Background" Value="Transparent"/>
                                               </Style>
                                           </Border.Styles> 
                                           
                                           <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                                                <!-- Status Dot -->
                                                <Ellipse Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Width="8" Height="8" Margin="0,2,8,0" VerticalAlignment="Top">
                                                    <Ellipse.Fill>
                                                        <SolidColorBrush Color="{Binding Status, Converter={StaticResource StatusColorConverter}}" />
                                                    </Ellipse.Fill>
                                                </Ellipse>

                                                <!-- Content -->
                                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="{Binding DisplayName}" 
                                                                   Classes.selected="{Binding $parent[ListBoxItem].IsSelected}"
                                                                   FontSize="13" 
                                                                   FontWeight="SemiBold">
                                                            <TextBlock.Styles>
                                                                <Style Selector="TextBlock.selected">
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </Style>
                                                                <Style Selector="TextBlock:not(.selected)">
                                                                    <Setter Property="Foreground" Value="#E6EDF3"/>
                                                                </Style>
                                                            </TextBlock.Styles>
                                                        </TextBlock>
                                                        <Border Background="#1B242A"
                                                                BorderBrush="#25303A"
                                                                BorderThickness="1"
                                                                CornerRadius="999"
                                                                Padding="6,1"
                                                                VerticalAlignment="Center"
                                                                IsVisible="{Binding ShowConnectionBadge}">
                                                            <TextBlock Text="{Binding ConnectionBadgeText}"
                                                                       FontSize="9"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#B7C1CC" />
                                                        </Border>
                                                    </StackPanel>
                                                    
                                                    <TextBlock Text="{Binding Endpoint}" 
                                                               Classes.selected="{Binding $parent[ListBoxItem].IsSelected}"
                                                               FontSize="11" 
                                                               FontFamily="JetBrains Mono, Consolas, monospace">
                                                         <TextBlock.Styles>
                                                            <Style Selector="TextBlock.selected">
                                                                <Setter Property="Foreground" Value="White"/> 
                                                                <Setter Property="Opacity" Value="0.9"/>
                                                            </Style>
                                                            <Style Selector="TextBlock:not(.selected)">
                                                                <Setter Property="Foreground" Value="#87909B"/>
                                                            </Style>
                                                        </TextBlock.Styles>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Stats Line -->
                                                 <Grid Grid.Row="1" Grid.Column="1" Margin="0,4,0,0" IsVisible="{Binding ShowStats}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" FontSize="10" 
                                                               Classes.selected="{Binding $parent[ListBoxItem].IsSelected}"
                                                               Margin="0,0,12,0">
                                                        <TextBlock.Styles>
                                                            <Style Selector="TextBlock.selected">
                                                                <Setter Property="Foreground" Value="White"/> 
                                                                <Setter Property="Opacity" Value="0.7"/>
                                                            </Style>
                                                            <Style Selector="TextBlock:not(.selected)">
                                                                <Setter Property="Foreground" Value="#87909B"/>
                                                            </Style>
                                                        </TextBlock.Styles>
                                                        <Run Text="{Binding TxLabel}" />
                                                        <Run Text=" " />
                                                        <Run Text="{Binding TxBytes}" FontWeight="SemiBold" Foreground="#3AA0FF" />
                                                    </TextBlock>
                                                    <TextBlock Grid.Column="1" FontSize="10" 
                                                               Classes.selected="{Binding $parent[ListBoxItem].IsSelected}">
                                                         <TextBlock.Styles>
                                                            <Style Selector="TextBlock.selected">
                                                                <Setter Property="Foreground" Value="White"/> 
                                                                <Setter Property="Opacity" Value="0.7"/>
                                                            </Style>
                                                            <Style Selector="TextBlock:not(.selected)">
                                                                <Setter Property="Foreground" Value="#87909B"/>
                                                            </Style>
                                                        </TextBlock.Styles>
                                                        <Run Text="{Binding RxLabel}" />
                                                        <Run Text=" " />
                                                        <Run Text="{Binding RxBytes}" FontWeight="SemiBold" Foreground="#2CB5A9" />
                                                    </TextBlock>
                                                </Grid>

                                                <!-- Settings Button -->
                                                <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" 
                                                        Content="⚙️" 
                                                        FontSize="14"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="4"
                                                        Margin="4,0,0,0"
                                                        Click="OnSessionSettingsClick"
                                                        VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
        </Border>
        </Grid>
    </Border>
</UserControl>
