<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ComCross.Shell.ViewModels"
             mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="700"
             x:Class="ComCross.Shell.Views.NotificationCenterView"
             x:DataType="vm:NotificationCenterViewModel">
    <Grid RowDefinitions="Auto,*" Background="{StaticResource Bg2Brush}">
        <Border BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="{Binding L[notifications.markAllRead]}" Click="OnMarkAllReadClick" />
                <Button Content="{Binding L[notifications.clearAll]}" Click="OnClearAllClick" Classes="secondary" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource Bg0Brush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0">
            <Grid>
                <TextBlock Text="{Binding L[notifications.empty]}" Foreground="{StaticResource Text2Brush}" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsVisible="{Binding IsEmpty}" />
                <ListBox ItemsSource="{Binding Items}" Background="{StaticResource Bg0Brush}" BorderThickness="0"
                         IsVisible="{Binding HasNotifications}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0"
                                                Spacing="6"
                                                Cursor="Hand"
                                                PointerPressed="OnNotificationMessagePressed">
                                        <TextBlock Text="{Binding Message}" FontSize="12" Foreground="{StaticResource Text0Brush}" TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" FontSize="11" Foreground="{StaticResource Text2Brush}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Button Grid.Column="1" 
                                            Content="✖" 
                                            FontSize="12" 
                                            Padding="6" 
                                            Background="Transparent" 
                                            Foreground="{StaticResource Text2Brush}"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            ToolTip.Tip="Delete"
                                            Click="OnDeleteClick"
                                            CommandParameter="{Binding Id}"
                                            VerticalAlignment="Top" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
