<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ComCross.Shell.ViewModels"
             x:Class="ComCross.Shell.Views.WorkloadTabs"
             x:DataType="vm:WorkloadTabsViewModel">

  <Border Background="#161D22" BorderBrush="#25303A" BorderThickness="0,0,0,1" Padding="12,8,12,0">
    <Grid ColumnDefinitions="*,Auto">
      <!-- Left: Workload Tabs (scrollable) -->
      <ScrollViewer Grid.Column="0" 
                    HorizontalScrollBarVisibility="Auto" 
                    VerticalScrollBarVisibility="Disabled">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <!-- Workload Tabs -->
          <ItemsControl ItemsSource="{Binding Tabs}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:WorkloadTabItemViewModel">
                <Border Name="TabBorder"
                        Classes.active="{Binding IsActive}"
                        Padding="14,10"
                        Cursor="Hand"
                        PointerPressed="OnTabBorderPointerPressed"
                        Background="#11181D"
                        BorderBrush="#22303B"
                        BorderThickness="1,1,1,0"
                        CornerRadius="10,10,0,0"
                        MinWidth="120"
                        ToolTip.Tip="{Binding FullName}">
                  
                  <Border.Styles>
                    <!-- Active Tab Style -->
                    <Style Selector="Border.active">
                      <Setter Property="Background" Value="#20303A" />
                      <Setter Property="BorderBrush" Value="#58B8FF" />
                    </Style>
                    
                    <!-- Hover Effect (only for inactive tabs) -->
                    <Style Selector="Border:not(.active):pointerover">
                      <Setter Property="Background" Value="#182128" />
                      <Setter Property="BorderBrush" Value="#2B3A45" />
                    </Style>
                  </Border.Styles>
                  
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                      <Border Width="8" Height="8" CornerRadius="999" Background="#3AA0FF" VerticalAlignment="Center" IsVisible="{Binding IsActive}" />
                      <Border Width="8" Height="8" CornerRadius="999" Background="#55626D" VerticalAlignment="Center" IsVisible="{Binding !IsActive}" />
                      <TextBlock Name="TabName"
                                 Text="{Binding DisplayName}" 
                                 FontSize="13" 
                                 FontWeight="SemiBold"
                                 VerticalAlignment="Center"
                                 Classes.active="{Binding IsActive}">
                        <TextBlock.Styles>
                          <Style Selector="TextBlock.active">
                            <Setter Property="Foreground" Value="#F6FBFF" />
                          </Style>
                          <Style Selector="TextBlock:not(.active)">
                            <Setter Property="Foreground" Value="#B7C1CC" />
                          </Style>
                        </TextBlock.Styles>
                      </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                      <Border Background="#173149"
                              BorderBrush="#2F6F9B"
                              BorderThickness="1"
                              CornerRadius="999"
                              Padding="8,2"
                              Margin="10,0,0,0"
                              IsVisible="{Binding IsActive}">
                        <TextBlock Text="{Binding ActiveBadge}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="#BDE3FF" />
                      </Border>

                      <Border Background="#24313A"
                              BorderBrush="#31424E"
                              BorderThickness="1"
                              CornerRadius="999"
                              Padding="8,2"
                              Margin="10,0,0,0"
                              IsVisible="{Binding IsDefault}">
                        <TextBlock Text="{Binding DefaultBadge}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="#B7C1CC" />
                      </Border>
                    </StackPanel>
                  </Grid>
                  
                  <!-- Context Menu -->
                  <Border.ContextMenu>
                    <ContextMenu>
                      <!-- Rename (all workloads) -->
                      <MenuItem Header="{Binding RenameHeader}" 
                                IsEnabled="{Binding CanRename}"
                                Command="{Binding RenameCommand}"
                                CommandParameter="{Binding Id}">
                        <MenuItem.Icon>
                          <TextBlock Text="✏️" />
                        </MenuItem.Icon>
                      </MenuItem>
                      
                      <!-- Copy (all workloads) -->
                      <MenuItem Header="{Binding CopyHeader}" 
                                IsEnabled="{Binding CanCopy}"
                                Command="{Binding CopyCommand}"
                                CommandParameter="{Binding Id}">
                        <MenuItem.Icon>
                          <TextBlock Text="📋" />
                        </MenuItem.Icon>
                      </MenuItem>
                      
                      <Separator IsVisible="{Binding CanDelete}" />
                      
                      <!-- Delete (except default) -->
                      <MenuItem Header="{Binding DeleteHeader}" 
                                IsEnabled="{Binding CanDelete}"
                                Command="{Binding DeleteCommand}"
                                CommandParameter="{Binding Id}">
                      </MenuItem>
                    </ContextMenu>
                  </Border.ContextMenu>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          
          <!-- New Workload Button -->
          <Button Content="＋" 
                  FontSize="16"
                  Background="#11181D"
                  BorderBrush="#22303B"
                  BorderThickness="1,1,1,0"
                  CornerRadius="10,10,0,0"
                  Padding="16,10"
                  VerticalAlignment="Center"
                  Command="{Binding CreateWorkloadCommand}"
              ToolTip.Tip="{Binding L[workload.new]}">
            <Button.Styles>
              <Style Selector="Button:pointerover">
                <Setter Property="Background" Value="#1A2530" />
              </Style>
            </Button.Styles>
          </Button>
        </StackPanel>
      </ScrollViewer>
      
      <!-- Right: Action Buttons (fixed width, float right) -->
      <StackPanel Grid.Column="1" 
                  Orientation="Horizontal" 
                  Spacing="4"
                  Margin="8,0">
        <!-- Notification Button -->
        <Button Content="🔔" 
                FontSize="20"
                Background="Transparent"
                BorderThickness="0"
                Padding="8"
                Click="OnNotificationsClick"
                ToolTip.Tip="{Binding L[action.notifications.tooltip]}">
          <Button.Styles>
            <Style Selector="Button:pointerover">
              <Setter Property="Background" Value="#1A2530" />
            </Style>
          </Button.Styles>
        </Button>
        <TextBlock Text="{Binding NotificationCenter.UnreadCount, StringFormat=({0})}" 
                   FontSize="11" 
                   Foreground="#F5A524" 
                   VerticalAlignment="Center" />
        
        <!-- Settings Button -->
        <Button Content="⚙️" 
                FontSize="20"
                Background="Transparent"
                BorderThickness="0"
                Padding="8"
                Click="OnSettingsClick"
                ToolTip.Tip="{Binding L[action.settings.tooltip]}">
          <Button.Styles>
            <Style Selector="Button:pointerover">
              <Setter Property="Background" Value="#1A2530" />
            </Style>
          </Button.Styles>
        </Button>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
