<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ComCross.Shell.Controls.SwitchCheckBox"
             x:Name="Root"
             Cursor="Hand"
             Focusable="True"
             MinHeight="28">
    <Border Classes="switch-checkbox-frame"
            CornerRadius="{StaticResource RadiusSm}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="1"
            Background="{StaticResource Bg1Brush}"
            Padding="8,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Stretch">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Grid Width="34" Height="18" VerticalAlignment="Center">
                <Border IsVisible="{Binding !IsChecked, ElementName=Root}"
                        CornerRadius="999"
                        Background="{StaticResource Bg2Brush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="1" />
                <Border IsVisible="{Binding IsChecked, ElementName=Root}"
                        CornerRadius="999"
                        Background="{StaticResource AccentBlueBrush}"
                        BorderBrush="{StaticResource AccentBlueBrightBrush}"
                        BorderThickness="1" />
                <Border IsVisible="{Binding !IsChecked, ElementName=Root}"
                        Width="14"
                        Height="14"
                        CornerRadius="999"
                        Background="{StaticResource Text2Brush}"
                        HorizontalAlignment="Left"
                        Margin="2,0,0,0" />
                <Border IsVisible="{Binding IsChecked, ElementName=Root}"
                        Width="14"
                        Height="14"
                        CornerRadius="999"
                        Background="{StaticResource WhiteBrush}"
                        HorizontalAlignment="Right"
                        Margin="0,0,2,0" />
            </Grid>
            <TextBlock Text="{Binding Label, ElementName=Root}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Text1Brush}"
                       VerticalAlignment="Center" />
        </StackPanel>
    </Border>
</UserControl>
