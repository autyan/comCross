<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:ComCross.Shell.Converters"
             x:Class="ComCross.Shell.App"
             RequestedThemeVariant="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Assets/Icons/IconResources.axaml" />
                <ResourceInclude Source="avares://AvaloniaEdit/Themes/Base.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:StatusColorConverter x:Key="StatusColorConverter"/>
            <converters:LevelColorConverter x:Key="LevelColorConverter"/>
            <converters:DirectionColorConverter x:Key="DirectionColorConverter"/>
            <converters:IndentMarginConverter x:Key="IndentMarginConverter"/>
            <converters:ListenerBackgroundConverter x:Key="ListenerBackgroundConverter"/>
            <converters:IsZeroConverter x:Key="IsZeroConverter"/>
        </ResourceDictionary>
    </Application.Resources>
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml"/>
        <StyleInclude Source="/Styles/DesignTokens.axaml"/>
        <StyleInclude Source="/Styles/ControlThemes.axaml"/>
        <StyleInclude Source="/Styles/CustomStyles.axaml"/>
    </Application.Styles>
</Application>
